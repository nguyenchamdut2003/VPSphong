<%- include('partials/panel-start', {
  user,
  activeNav: 'logs',
  pageTitle: 'Lịch sử thao tác',
  headerTitle: 'Quản Lý Dịch Vụ',
  headerSubtitle: 'Quản Lý Cloud VPS'
}) %>

<div class="bg-white rounded-3xl border border-slate-100 shadow-sm overflow-hidden">
  <div class="px-6 py-4 border-b border-gray-100">
    <h2 class="text-lg font-extrabold text-gray-900 border-l-4 border-cyan-500 pl-3">Lịch Sử Thao Tác</h2>
    <p class="text-xs text-gray-500 mt-1">Nhật ký thao tác trên VPS của bạn</p>
  </div>

  <div class="px-6 py-4 flex flex-col md:flex-row md:items-center md:justify-between gap-3 border-b border-gray-50 bg-gray-50/50">
    <div class="flex items-center gap-2 text-xs text-gray-600">
      <span>Show</span>
      <select id="logPageSize" class="border border-gray-200 rounded-lg px-2 py-1.5 text-xs font-semibold bg-white outline-none focus:ring-2 focus:ring-blue-500/30">
        <option value="10" selected>10</option>
        <option value="25">25</option>
        <option value="50">50</option>
        <option value="9999">All</option>
      </select>
      <span>entries</span>
    </div>
    <div class="flex items-center gap-2 text-xs">
      <span class="text-gray-600 font-medium">Search:</span>
      <input type="search" id="logSearch" class="border border-gray-200 rounded-lg px-3 py-1.5 text-xs w-full md:w-56 outline-none focus:ring-2 focus:ring-blue-500/30" placeholder="Lệnh, IP, mô tả..." autocomplete="off">
    </div>
  </div>

  <div class="overflow-x-auto">
    <table class="min-w-full text-left text-xs md:text-sm">
      <thead class="bg-gray-50 text-gray-500 uppercase text-[11px] tracking-wide border-b border-gray-100">
        <tr>
          <th class="px-5 py-3 font-bold">ID</th>
          <th class="px-5 py-3 font-bold">Thời gian</th>
          <th class="px-5 py-3 font-bold">Lệnh</th>
          <th class="px-5 py-3 font-bold">VPS IP</th>
          <th class="px-5 py-3 font-bold">Chi tiết</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-100">
        <% logs.forEach((log, idx) => {
             const ip = log.userVpsId && log.userVpsId.ip ? log.userVpsId.ip : '';
             const blob = [log.action || '', ip, (log.description || '')].join(' ').toLowerCase();
        %>
        <tr class="log-row hover:bg-gray-50/80" data-search="<%= blob %>">
          <td class="px-5 py-3 font-semibold log-id"><%= idx + 1 %></td>
          <td class="px-5 py-3 text-gray-600 whitespace-nowrap"><%= new Date(log.createdAt).toLocaleString('vi-VN') %></td>
          <td class="px-5 py-3">
            <% if (log.action === 'start' || log.action === 'renew' || log.action === 'buy') { %>
              <span class="px-2 py-1 rounded-md text-[11px] font-bold bg-cyan-100 text-cyan-800 uppercase"><%= log.action %></span>
            <% } else { %>
              <span class="px-2 py-1 rounded-md text-[11px] font-bold bg-red-100 text-red-700 uppercase"><%= log.action %></span>
            <% } %>
          </td>
          <td class="px-5 py-3 font-mono text-[11px] text-blue-700 font-semibold"><%= ip || '—' %></td>
          <td class="px-5 py-3 text-gray-600 text-[11px] max-w-md"><%= log.description || '' %></td>
        </tr>
        <% }) %>
        <% if (logs.length === 0) { %>
        <tr><td colspan="5" class="px-5 py-10 text-center text-gray-500 font-medium">Chưa có thao tác</td></tr>
        <% } %>
      </tbody>
    </table>
  </div>

  <% if (logs.length) { %>
  <div class="px-6 py-3 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3 border-t border-gray-100 bg-gray-50/50 text-xs text-gray-600">
    <div id="logInfo">Showing 0 to 0 of 0 entries</div>
    <div class="flex items-center gap-2">
      <button type="button" id="logPrev" class="px-3 py-1.5 rounded-lg border border-gray-200 bg-white font-semibold hover:bg-gray-50 disabled:opacity-40 disabled:pointer-events-none">Previous</button>
      <span id="logPage" class="px-3 py-1.5 rounded-lg bg-cyan-500 text-white font-bold text-xs">1</span>
      <button type="button" id="logNext" class="px-3 py-1.5 rounded-lg border border-gray-200 bg-white font-semibold hover:bg-gray-50 disabled:opacity-40 disabled:pointer-events-none">Next</button>
    </div>
  </div>
  <% } %>
</div>

<% if (logs.length) { %>
<script>
(function () {
  var rows = Array.prototype.slice.call(document.querySelectorAll('tr.log-row'));
  var sizeEl = document.getElementById('logPageSize');
  var searchEl = document.getElementById('logSearch');
  var page = 1;

  function filtered() {
    var q = (searchEl.value || '').trim().toLowerCase();
    return rows.filter(function (r) {
      var b = (r.getAttribute('data-search') || '').toLowerCase();
      return !q || b.indexOf(q) !== -1;
    });
  }

  function render() {
    var all = filtered();
    var size = parseInt(sizeEl.value, 10) || 10;
    var total = all.length;
    var pages = Math.max(1, Math.ceil(total / size));
    if (page > pages) page = pages;
    var start = total === 0 ? 0 : (page - 1) * size + 1;
    var end = Math.min(page * size, total);

    rows.forEach(function (r) { r.classList.add('hidden'); });
    all.forEach(function (r, i) {
      var c = r.querySelector('.log-id');
      if (c) c.textContent = String(i + 1);
      if (i >= (page - 1) * size && i < page * size) r.classList.remove('hidden');
    });

    document.getElementById('logInfo').textContent = total === 0 ? 'Showing 0 to 0 of 0 entries' : ('Showing ' + start + ' to ' + end + ' of ' + total + ' entries');
    document.getElementById('logPage').textContent = String(page);
    document.getElementById('logPrev').disabled = page <= 1;
    document.getElementById('logNext').disabled = page >= pages || total === 0;
  }

  sizeEl.addEventListener('change', function () { page = 1; render(); });
  searchEl.addEventListener('input', function () { page = 1; render(); });
  document.getElementById('logPrev').addEventListener('click', function () { if (page > 1) { page--; render(); } });
  document.getElementById('logNext').addEventListener('click', function () {
    var all = filtered();
    var sz = parseInt(sizeEl.value, 10) || 10;
    var pages = Math.max(1, Math.ceil(all.length / sz));
    if (page < pages) { page++; render(); }
  });
  render();
})();
</script>
<% } %>

<%- include('partials/panel-end') %>
