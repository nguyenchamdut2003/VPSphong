<%- include('partials/panel-start', {
  user,
  activeNav: 'vps',
  pageTitle: 'Quản Lý VPS',
  headerTitle: 'Quản Lý Dịch Vụ',
  headerSubtitle: 'Quản Lý Cloud VPS'
}) %>

<div class="max-w-6xl mx-auto mb-8">
    <div class="text-center mb-10 mt-6">
        <h2 class="text-3xl md:text-4xl font-black text-gray-900 tracking-tight mb-3">Giao Diện Quản Lý Thông Minh</h2>
        <p class="text-lg text-gray-500 font-medium">Bạn hoàn toàn làm chủ server VPS với các thao tác click đơn giản.</p>
    </div>

    <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4 mb-8 bg-sky-50/50 p-4 rounded-[2rem] border border-sky-100">
        <div class="flex items-center gap-3">
            <a href="/" class="inline-flex items-center justify-center gap-2 px-5 py-2.5 rounded-full bg-white text-sky-700 text-sm font-black hover:bg-sky-50 shadow-sm border border-sky-200 transition">
                <i class="fa-solid fa-cart-plus"></i> Đăng Ký VPS Mới
            </a>
        </div>
        <div class="relative max-w-sm w-full">
            <div class="absolute inset-y-0 left-0 flex items-center pl-4 pointer-events-none text-sky-500">
                <i class="fa-solid fa-magnifying-glass"></i>
            </div>
            <input type="search" id="vpsTableSearch" class="block w-full p-3 pl-10 text-sm font-bold text-gray-900 bg-white border border-sky-200 rounded-full focus:ring-4 focus:ring-sky-500/20 focus:border-sky-400 outline-none transition" placeholder="Tìm theo IP, Tên gói, ID...">
        </div>
    </div>

    <% if (!userVpsList.length) { %>
    <div class="bg-white rounded-[2rem] border-2 border-dashed border-gray-200 p-16 text-center shadow-sm">
        <div class="text-6xl text-gray-200 mb-6"><i class="fa-solid fa-box-open"></i></div>
        <h3 class="text-2xl font-black text-gray-900 mb-2">Bạn chưa sở hữu VPS nào!</h3>
        <p class="text-gray-500 font-medium mb-8">Nhanh tay thu thập một Cloud chuẩn Ninja với giá cực sốc.</p>
        <a href="/" class="inline-flex items-center gap-2 px-8 py-4 rounded-full bg-sky-500 text-white text-lg font-black hover:bg-sky-600 transition shadow-xl shadow-sky-500/30">
            <i class="fa-solid fa-rocket"></i> Chọn VPS ngay
        </a>
    </div>
    <% } else { %>
    <div class="space-y-6">
        <% userVpsList.forEach((uv, idx) => {
            const st = uv.status;
            const vid = uv.vpsId;
            const cycleDays = uv.renewalPeriodDays || (vid && vid.billingCycleDays) || 30;
            const durationLabel = (cycleDays >= 28 && cycleDays <= 31) ? '1 Tháng' : (cycleDays + ' ngày');
            const exp = new Date(uv.expireDate);
            const pad = (n) => String(n).padStart(2, '0');
            const expStr = pad(exp.getDate()) + '/' + pad(exp.getMonth() + 1) + '/' + exp.getFullYear() + ' ' + pad(exp.getHours()) + ':' + pad(exp.getMinutes());
            
            const vpsCode = (vid && typeof vid.saleCode === 'number' && vid.saleCode > 0)
                ? ('#vpsphong' + vid.saleCode)
                : (vid ? ('#vpsphong' + String(vid._id).slice(-6)) : '#unknown');
            const vpsName = vid ? vid.name : 'VPS Tùy Chọn';
            const catName = (vid && vid.categoryId && vid.categoryId.name) ? vid.categoryId.name : '';
            const ip = uv.ip || '';
            const cfg = vid ? (vid.cpu + 'C / ' + vid.ram + 'G / ' + vid.disk + 'G') : '—';
            const sshUser = (uv.username && String(uv.username).trim()) || 'root';
            const plainPw = (uv.password && String(uv.password)) || '';
            const searchBlob = (vpsName + ' ' + vpsCode + ' ' + catName + ' ' + ip).toLowerCase();
            
            let statusDot = 'bg-gray-400';
            let statusAnim = '';
            let statusText = 'Không xác định';

            if (st === 'running') {
                statusDot = 'bg-emerald-500';
                statusAnim = 'animate-pulse shadow-lg shadow-emerald-500/50';
                statusText = 'Đang chạy';
            } else if (st === 'stopped') {
                statusDot = 'bg-amber-500';
                statusText = 'Đã dừng';
            } else if (st === 'expired' || st === 'suspended') {
                statusDot = 'bg-rose-500';
                statusText = 'Hết hạn';
            }
        %>
        <div class="vps-card bg-white rounded-[2rem] shadow-xl shadow-sky-900/5 p-8 border border-sky-100 relative overflow-hidden transition-all duration-300 hover:shadow-2xl hover:border-sky-300" data-search="<%= searchBlob %>">
            <div class="absolute top-0 right-0 p-8 text-sky-50 pointer-events-none"><i class="fa-solid fa-server text-8xl"></i></div>
            
            <div class="border border-gray-100 bg-gray-50 rounded-2xl p-6 md:p-8 flex flex-col md:flex-row justify-between items-start md:items-center gap-8 relative z-10">
                <div class="flex-1 w-full md:w-auto">
                    <div class="flex items-center gap-3 mb-2">
                        <div class="flex items-center gap-1.5 px-2.5 py-1 rounded-full bg-white border border-gray-200 shadow-sm text-[10px] font-black uppercase tracking-wider text-gray-500">
                           <div class="w-2.5 h-2.5 rounded-full <%= statusDot %> <%= statusAnim %>"></div>
                           <%= statusText %>
                        </div>
                        <h3 class="font-black text-xl md:text-2xl text-gray-900 tracking-tight"><%= vpsName %> <span class="text-sky-600 text-lg ml-1"><%= vpsCode %></span></h3>
                    </div>
                    
                    <div class="flex flex-wrap items-center gap-x-4 gap-y-2 text-sm text-gray-500 font-medium mb-4">
                        <% if(catName) { %><span class="bg-sky-100 text-sky-700 px-2.5 py-0.5 rounded uppercase tracking-wider text-[11px] font-bold"><%= catName %></span><% } %>
                        <span><i class="fa-solid fa-microchip mr-1.5 text-gray-400"></i>Cấu hình: <%= cfg %></span>
                        <span><i class="fa-regular fa-clock mr-1.5 text-gray-400"></i>Hết hạn: <strong class="text-gray-700"><%= expStr %></strong></span>
                    </div>

                    <div class="flex flex-col sm:flex-row gap-3 sm:gap-6 mt-4 text-[13px] bg-white p-4 rounded-xl border border-sky-100 shadow-sm user-vps-pw-cell max-w-2xl">
                        <div class="font-medium text-gray-600 flex items-center">
                            <span class="w-10 text-gray-400">IP:</span>
                            <span class="font-mono font-bold text-gray-900 ml-1 bg-sky-50 px-2 py-1 rounded text-sm"><%= ip || '—' %></span>
                        </div>
                        <div class="font-medium text-gray-600 flex items-center">
                            <span class="w-10 text-gray-400">User:</span>
                            <span class="font-mono font-bold text-gray-900 ml-1 bg-gray-50 px-2 py-1 rounded text-sm"><%= sshUser %></span>
                        </div>
                        <div class="font-medium text-gray-600 flex items-center gap-2 relative">
                            <span class="w-10 text-gray-400">Pass:</span>
                            <% if (plainPw) { %>
                                <div class="bg-gray-50 px-2 py-1 rounded flex items-center gap-3">
                                    <span class="user-vps-pw-masked font-mono font-bold text-gray-900 text-sm select-none tracking-widest mt-0.5">••••••••</span>
                                    <span class="user-vps-pw-plain hidden font-mono font-bold text-gray-900 text-sm select-none"><%= plainPw %></span>
                                    <button class="user-vps-pw-toggle text-sky-500 hover:text-sky-600 transition"><i class="fas fa-eye"></i></button>
                                </div>
                            <% } else { %>
                                <span class="bg-gray-50 text-gray-400 px-2 py-1 rounded font-mono text-sm">—</span>
                            <% } %>
                        </div>
                    </div>
                </div>
                
                <div class="flex flex-row md:flex-col lg:flex-row flex-wrap gap-3 shrink-0 self-stretch md:self-center">
                    <form action="/user/vps-action" method="POST" class="inline flex-1">
                        <input type="hidden" name="userVpsId" value="<%= uv._id %>">
                        <input type="hidden" name="action" value="restart">
                        <button class="w-full px-5 py-3 md:py-3.5 bg-amber-500 hover:bg-amber-600 text-white rounded-xl text-xs font-black uppercase tracking-wider transition shadow-md shadow-amber-500/20 whitespace-nowrap"><i class="fa-solid fa-rotate-right mr-1.5 text-amber-200"></i> Restart</button>
                    </form>
                    
                    <form action="/user/vps-action" method="POST" class="inline flex-1">
                        <input type="hidden" name="userVpsId" value="<%= uv._id %>">
                        <% if (st === 'running') { %>
                        <input type="hidden" name="action" value="stop">
                        <button class="w-full px-5 py-3 md:py-3.5 bg-rose-500 hover:bg-rose-600 text-white rounded-xl text-xs font-black uppercase tracking-wider transition shadow-md shadow-rose-500/20 whitespace-nowrap"><i class="fa-solid fa-stop mr-1.5 text-rose-200"></i> Stop</button>
                        <% } else { %>
                        <input type="hidden" name="action" value="start">
                        <button class="w-full px-5 py-3 md:py-3.5 bg-emerald-500 hover:bg-emerald-600 text-white rounded-xl text-xs font-black uppercase tracking-wider transition shadow-md shadow-emerald-500/20 whitespace-nowrap"><i class="fa-solid fa-play mr-1.5 text-emerald-200"></i> Start</button>
                        <% } %>
                    </form>
                </div>
            </div>
            
            <div class="mt-6 flex flex-wrap justify-between items-center border-t border-gray-50 pt-5 gap-4">
                <form action="/user/toggle-autorenew" method="POST" class="inline">
                    <input type="hidden" name="userVpsId" value="<%= uv._id %>">
                    <button class="text-xs font-black px-5 py-2.5 rounded-full flex items-center gap-2 uppercase tracking-wide <%= uv.autoRenew ? 'bg-sky-50 text-sky-700 hover:bg-sky-100 border border-sky-200' : 'bg-gray-50 text-gray-500 hover:bg-gray-100 border border-gray-200' %> transition shadow-sm">
                        <i class="fa-solid fa-rotate <%= uv.autoRenew ? 'animate-spin-slow' : '' %>"></i> Auto Renew: <%= uv.autoRenew ? 'ĐANG BẬT' : 'TẮT' %>
                    </button>
                </form>
                <form action="/user/renew" method="POST" class="inline">
                    <input type="hidden" name="userVpsId" value="<%= uv._id %>">
                    <button class="px-8 py-3 bg-gray-900 hover:bg-sky-500 text-white rounded-full text-xs font-black uppercase tracking-widest transition shadow-xl shadow-gray-900/20 hover:shadow-sky-500/40">Thanh toán Gia Hạn</button>
                </form>
            </div>
        </div>
        <% }) %>
    </div>
    <% } %>
</div>

<style>
.animate-spin-slow {
   animation: spin 3s linear infinite;
}
@keyframes spin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}
</style>

<script>
document.addEventListener('DOMContentLoaded', function () {
  const searchEl = document.getElementById('vpsTableSearch');
  const cards = document.querySelectorAll('.vps-card');

  if (searchEl) {
    searchEl.addEventListener('input', function (e) {
      const q = e.target.value.toLowerCase().trim();
      cards.forEach(card => {
        const searchBlob = card.getAttribute('data-search') || '';
        if (!q || searchBlob.includes(q)) {
          card.style.display = '';
        } else {
          card.style.display = 'none';
        }
      });
    });
  }

  document.querySelectorAll('.user-vps-pw-toggle').forEach(function (btn) {
    btn.addEventListener('click', function (ev) {
      ev.preventDefault();
      const cell = btn.closest('.user-vps-pw-cell');
      if (!cell) return;
      const masked = cell.querySelector('.user-vps-pw-masked');
      const plain = cell.querySelector('.user-vps-pw-plain');
      const icon = btn.querySelector('i');
      if (!masked || !plain || !icon) return;
      
      const isHidden = plain.classList.contains('hidden');
      if (isHidden) {
          plain.classList.remove('hidden');
          masked.classList.add('hidden');
          icon.className = 'fas fa-eye-slash';
      } else {
          plain.classList.add('hidden');
          masked.classList.remove('hidden');
          icon.className = 'fas fa-eye';
      }
    });
  });
});
</script>

<%- include('partials/panel-end') %>
