<%- include('partials/panel-start', {
  user,
  activeNav: 'upthue',
  pageTitle: 'Đơn Up thuê',
  headerTitle: 'Up Thuê Ninja',
  headerSubtitle: 'Lịch sử đơn của bạn'
}) %>

<div class="max-w-6xl mx-auto">
  <div class="mb-4 flex flex-wrap items-center justify-between gap-3">
    <a href="/user/up-thue" class="inline-flex items-center gap-2 px-5 py-2.5 rounded-xl bg-cyan-500 hover:bg-cyan-600 text-white text-sm font-black transition"><i class="fa-solid fa-plus"></i> Đặt đơn mới</a>
  </div>

  <% if (error) { %>
  <div class="mb-4 rounded-xl border border-rose-200 bg-rose-50 px-4 py-3 text-sm font-semibold text-rose-800"><%= error %></div>
  <% } %>

  <div class="bg-white rounded-3xl border border-slate-100 shadow-sm overflow-hidden">
    <% if (!list || !list.length) { %>
    <div class="p-12 text-center text-gray-500 font-medium">Chưa có đơn up thuê. <a href="/user/up-thue" class="text-cyan-600 font-bold underline">Đặt ngay</a></div>
    <% } else { %>
    <div class="overflow-x-auto">
      <table class="min-w-full text-left text-sm">
        <thead class="bg-gray-50 text-gray-500 text-xs uppercase border-b border-gray-100">
          <tr>
            <th class="px-5 py-3 font-bold">Mã</th>
            <th class="px-5 py-3 font-bold">Gói up</th>
            <th class="px-5 py-3 font-bold">Gói TG / SV / Map</th>
            <th class="px-5 py-3 font-bold">Thời gian</th>
            <th class="px-5 py-3 font-bold">Tiền</th>
            <th class="px-5 py-3 font-bold">Trạng thái</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100">
          <% list.forEach(function(item) {
               const st = item.status || '';
               const stClass = st === 'Hoàn thành' ? 'bg-emerald-100 text-emerald-800'
                 : (st === 'Đang làm' ? 'bg-blue-100 text-blue-800'
                 : (st === 'Đang chờ' ? 'bg-amber-100 text-amber-800' : 'bg-gray-100 text-gray-700'));
          %>
          <tr class="hover:bg-gray-50/80">
            <td class="px-5 py-3 font-mono font-bold text-cyan-700">#<%= item.maupthue %></td>
            <td class="px-5 py-3 text-gray-800"><%= item.goiupLabel %></td>
            <td class="px-5 py-3 text-xs text-gray-600"><%= item.timeLabel %> · <%= item.serverLabel %> · map <%= item.map %></td>
            <td class="px-5 py-3 text-gray-600 whitespace-nowrap"><%= item.songay %> ngày<br><span class="text-[11px]"><%= item.timestartText %> → <%= item.timeendText %></span></td>
            <td class="px-5 py-3 font-bold text-rose-600"><%= item.giaText %></td>
            <td class="px-5 py-3"><span class="px-2.5 py-1 rounded-full text-[11px] font-bold <%= stClass %>"><%= st %></span></td>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
    <% } %>
  </div>
</div>

<%- include('partials/panel-end') %>
