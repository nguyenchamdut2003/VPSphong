<% const ss = typeof supportSettings !== 'undefined' && supportSettings ? supportSettings : {}; %>
<% const zUrl = (ss.supportZaloUrl && String(ss.supportZaloUrl).trim()) || ''; %>
<% const fbUrl = (ss.supportFacebookUrl && String(ss.supportFacebookUrl).trim()) || ''; %>
<% if (zUrl || fbUrl) { %>
<div class="fixed right-3 bottom-6 z-40 flex flex-col gap-2 items-center" id="supportFloatBar">
  <div class="bg-white rounded-3xl shadow-xl border border-cyan-100 p-2 flex flex-col gap-2">
    <span class="text-[10px] font-bold text-gray-400 uppercase text-center px-1 tracking-wide">Hỗ trợ</span>
    <% if (zUrl) { %>
    <a href="<%= zUrl %>" target="_blank" rel="noopener noreferrer" class="w-11 h-11 rounded-xl bg-[#0068FF] hover:bg-[#0052cc] text-white flex items-center justify-center shadow-md transition hover:scale-105 text-lg font-black tracking-tight" title="Zalo">Z</a>
    <% } %>
    <% if (fbUrl) { %>
    <a href="<%= fbUrl %>" target="_blank" rel="noopener noreferrer" class="w-11 h-11 rounded-xl bg-[#1877F2] hover:bg-[#0e5fc7] text-white flex items-center justify-center text-xl shadow-md transition hover:scale-105" title="Facebook">
      <i class="fa-brands fa-facebook-f"></i>
    </a>
    <% } %>
  </div>
</div>
<% } %>
