<%- include('partials/panel-start', {
  user,
  activeNav: 'dashboard',
  pageTitle: 'Trang chủ',
  headerTitle: 'Quản Lý Dịch Vụ',
  headerSubtitle: 'Quản Lý Cloud VPS'
}) %>

<div class="grid gap-6 lg:grid-cols-3">
  <div class="lg:col-span-2 space-y-6">
    <div id="tai-khoan" class="bg-white rounded-3xl border border-slate-100 shadow-sm p-6 scroll-mt-6">
      <h2 class="text-lg font-extrabold text-gray-900 border-l-4 border-blue-500 pl-3 mb-2">Tài khoản</h2>
      <p class="text-sm text-gray-500 mb-6">Xin chào, <span class="font-bold text-blue-700"><%= user.username %></span></p>
      <div class="rounded-3xl bg-gradient-to-br from-cyan-50 to-blue-50 border border-cyan-100 p-6 text-center">
        <p class="text-xs font-bold text-gray-500 uppercase tracking-wide mb-1">Số dư hiện tại</p>
        <p class="text-3xl md:text-4xl font-extrabold text-cyan-600"><%= user.balance.toLocaleString() %> <span class="text-lg text-gray-500 font-bold">VNĐ</span></p>
      </div>
    </div>

    <div id="nap-ngan-hang" class="bg-white rounded-3xl border border-slate-100 shadow-sm p-6 scroll-mt-6">
      <h2 class="text-lg font-extrabold text-gray-900 border-l-4 border-cyan-500 pl-3 mb-2">Nạp tiền ngân hàng</h2>
      <p class="text-sm text-gray-500 mb-4">
        Quét QR / chuyển khoản trên trang <strong>Chuyển khoản</strong> — nội dung CK phải là
        <code class="bg-gray-100 px-1.5 py-0.5 rounded text-red-600 font-mono text-xs">SEVQR <%= user.username %></code>.
      </p>
      <a href="/user/chuyen-khoan" class="inline-flex items-center gap-2 px-5 py-3 rounded-xl bg-cyan-500 text-white text-sm font-bold hover:bg-cyan-600 transition shadow-lg shadow-cyan-500/20">
        <i class="fa-solid fa-building-columns"></i> Nạp ngân hàng &amp; xem lịch sử nạp
      </a>
    </div>
  </div>

  <div class="space-y-4">
    <div class="bg-white rounded-3xl border border-slate-100 shadow-sm p-5">
      <h3 class="font-bold text-gray-800 mb-3 text-sm">Lối tắt</h3>
      <div class="space-y-2 text-sm">
        <a href="/user/chuyen-khoan" class="flex items-center justify-between py-2 px-3 rounded-xl hover:bg-gray-50 text-gray-700 font-semibold border border-transparent hover:border-gray-100">
          <span><i class="fa-solid fa-qrcode text-cyan-600 mr-2"></i>Nạp ngân hàng</span>
          <i class="fa-solid fa-chevron-right text-gray-300 text-xs"></i>
        </a>
        <a href="/user/vps" class="flex items-center justify-between py-2 px-3 rounded-xl hover:bg-gray-50 text-gray-700 font-semibold border border-transparent hover:border-gray-100">
          <span><i class="fa-solid fa-server text-blue-600 mr-2"></i>Quản lý VPS</span>
          <i class="fa-solid fa-chevron-right text-gray-300 text-xs"></i>
        </a>
        <a href="/user/history" class="flex items-center justify-between py-2 px-3 rounded-xl hover:bg-gray-50 text-gray-700 font-semibold">
          <span><i class="fa-solid fa-wallet text-cyan-600 mr-2"></i>Lịch sử giao dịch</span>
          <i class="fa-solid fa-chevron-right text-gray-300 text-xs"></i>
        </a>
        <a href="/" class="flex items-center justify-between py-2 px-3 rounded-xl hover:bg-gray-50 text-gray-700 font-semibold">
          <span><i class="fa-solid fa-cart-shopping text-indigo-600 mr-2"></i>Mua thêm VPS</span>
          <i class="fa-solid fa-chevron-right text-gray-300 text-xs"></i>
        </a>
      </div>
    </div>
  </div>
</div>

<%- include('partials/panel-end') %>
