<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>vpsphong.pro - Thuê VPS Ninja School Tối Ưu</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.6.0/css/all.min.css">
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=Press+Start+2P&display=swap');
        body { font-family: 'Inter', system-ui, sans-serif; scroll-behavior: smooth; }
        .logo-text { font-family: 'Press Start 2P', sans-serif; background: linear-gradient(90deg, #67e8f9, #22d3ee); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }
        .hero-bg { background: linear-gradient(135deg, #0ea5e9 0%, #0369a1 100%); }
        .ninja-icon { animation: float 3s ease-in-out infinite; }
        @keyframes float {
            0% { transform: translateY(0px) rotate(12deg); }
            50% { transform: translateY(-10px) rotate(15deg); }
            100% { transform: translateY(0px) rotate(12deg); }
        }
    </style>
</head>
<body class="bg-gray-50 text-gray-800">

    <!-- NAVBAR -->
    <nav class="bg-white/95 backdrop-blur-md border-b border-sky-100 sticky top-0 z-50 shadow-sm">
        <div class="max-w-7xl mx-auto px-6 py-4 flex flex-wrap items-center justify-between gap-4">
            <a href="/" class="flex flex-shrink-0 items-center gap-3">
                <div class="w-12 h-12 bg-gradient-to-br from-cyan-400 to-sky-600 rounded-2xl flex items-center justify-center text-3xl shadow-xl border-4 border-white rotate-12 ninja-icon">🥷</div>
                <div>
                    <span class="logo-text text-2xl md:text-4xl tracking-tighter block leading-none">VPS</span>
                    <span class="text-sky-600 text-sm md:text-lg font-bold block mt-1 tracking-wide">phong.pro</span>
                </div>
            </a>
            
            <div class="hidden md:flex items-center gap-8 text-sm font-bold text-gray-500 uppercase tracking-wide">
                <a href="#mua-vps" class="hover:text-cyan-600 transition">Bảng Giá</a>
                <% if (typeof user !== 'undefined' && user) { %>
                  <a href="/user/vps" class="hover:text-cyan-600 transition">Quản Lý VPS</a>
                  <a href="/user/chuyen-khoan" class="hover:text-cyan-600 transition">Nạp Tiền</a>
                <% } else { %>
                  <a href="/login" class="hover:text-cyan-600 transition">Hệ Thống</a>
                <% } %>
                <a href="#huong-dan" class="hover:text-cyan-600 transition">Hướng Dẫn</a>
                <a href="#lien-he" class="hover:text-cyan-600 transition">Liên Hệ</a>
            </div>
            
            <div class="flex gap-2.5 items-center ml-auto md:ml-0">
                <% if (typeof user !== 'undefined' && user) { %>
                  <span class="hidden md:inline font-black text-emerald-600 mr-2 text-lg"><%= user.balance.toLocaleString() %>đ</span>
                  <a href="<%= (typeof isAdmin !== 'undefined' && isAdmin) ? '/admin' : '/user/dashboard' %>" class="bg-gray-900 hover:bg-cyan-600 text-white px-5 py-2.5 rounded-2xl text-sm font-bold flex items-center gap-2 transition shadow-md shadow-gray-900/10">Menu</a>
                  <a href="/logout" class="bg-rose-50 text-rose-500 hover:bg-rose-500 hover:text-white px-4 py-2.5 rounded-2xl text-sm font-bold transition">Thoát</a>
                <% } else { %>
                  <a href="/login" class="text-sky-600 hover:bg-sky-50 px-5 py-2.5 rounded-2xl text-sm font-black transition">Đăng Nhập</a>
                  <a href="/register" class="bg-sky-500 hover:bg-sky-600 text-white px-6 py-2.5 rounded-2xl text-sm font-black flex items-center gap-2 transition shadow-lg shadow-sky-500/30">Đăng Ký</a>
                <% } %>
            </div>
        </div>
    </nav>

    <!-- BANNER PHONG CÁCH NINJA -->
    <section class="hero-bg text-white py-16 md:py-28 relative overflow-hidden">
        <div class="absolute inset-0 bg-[url('https://www.transparenttextures.com/patterns/cubes.png')] opacity-10"></div>
        <div class="max-w-6xl mx-auto px-6 text-center relative z-10">
            <div class="inline-flex items-center gap-3 bg-white/10 backdrop-blur-md px-5 py-2 rounded-full mb-8 border border-white/20">
                <span class="text-2xl">🥷</span>
                <span class="text-lg md:text-xl font-bold tracking-widest text-sky-50 uppercase">NINJA SCHOOL VPS</span>
            </div>
            <h1 class="text-4xl md:text-6xl lg:text-7xl font-black leading-tight mb-6">Trải nghiệm vượt trội<br><span class="text-transparent bg-clip-text bg-gradient-to-r from-cyan-300 to-sky-100">Chơi NSO Siêu Mượt</span></h1>
            <p class="text-lg md:text-2xl mb-12 text-sky-100 font-medium max-w-3xl mx-auto">Tối ưu riêng cho Ninja School và treo máy tự động. Proxy IP Sạch • Lỗi hoàn tiền.</p>
            
            <div class="flex flex-col sm:flex-row justify-center gap-4">
                <a href="#mua-vps" class="bg-white text-sky-600 px-8 py-4 rounded-full text-lg font-bold hover:scale-105 transition shadow-2xl shadow-cyan-900/50">Chọn Gói Cấu Hình Vừa Túi Tiền</a>
                <a href="<%=(typeof user!=='undefined'&&user)?'/user/vps':'/login'%>" class="bg-transparent border-2 border-white/30 text-white px-8 py-4 rounded-full text-lg font-bold hover:bg-white/10 transition backdrop-blur-sm">Quản Lý VPS của tôi</a>
            </div>
        </div>
        <!-- Ninja decoration -->
        <div class="absolute -bottom-8 -right-8 text-[12rem] opacity-[0.08] ninja-icon pointer-events-none drop-shadow-2xl">🥷</div>
        <div class="absolute top-12 left-8 text-8xl opacity-[0.08] rotate-12 ninja-icon pointer-events-none">🥷</div>
    </section>

    <!-- MUA VPS -->
    <section id="mua-vps" class="max-w-7xl mx-auto px-6 py-20">
        <h2 class="text-4xl font-black text-center text-gray-900 mb-4 tracking-tight">Chọn VPS Phù Hợp Cho Bạn</h2>
        <p class="text-center text-xl text-gray-500 font-medium mb-12 max-w-2xl mx-auto">Giá thành cực kỳ rẻ, chất lượng ổn định cao nhất, hoàn toàn tự động kích hoạt.</p>

        <!-- Chọn thời gian -->
        <div class="flex justify-center mb-12">
            <div class="bg-white rounded-full shadow-sm border border-gray-100 p-1.5 flex flex-wrap gap-1">
                <button onclick="setMonth(1)" id="month-1" class="month-btn active px-6 py-3 rounded-full font-bold text-sm text-gray-600 hover:text-sky-600 transition">1 Tháng</button>
                <button onclick="setMonth(3)" id="month-3" class="month-btn px-6 py-3 rounded-full font-bold text-sm text-gray-600 hover:text-sky-600 transition flex items-center gap-1.5">3 Tháng <span class="bg-emerald-100 text-emerald-700 px-2 py-0.5 rounded-full text-[10px]">-10%</span></button>
                <button onclick="setMonth(6)" id="month-6" class="month-btn px-6 py-3 rounded-full font-bold text-sm text-gray-600 hover:text-sky-600 transition flex items-center gap-1.5 hidden sm:flex">6 Tháng <span class="bg-emerald-100 text-emerald-700 px-2 py-0.5 rounded-full text-[10px]">-14%</span></button>
                <button onclick="setMonth(12)" id="month-12" class="month-btn px-6 py-3 rounded-full font-bold text-sm text-gray-600 hover:text-sky-600 transition flex items-center gap-1.5 hidden md:flex">12 Tháng <span class="bg-emerald-100 text-emerald-700 px-2 py-0.5 rounded-full text-[10px]">-17%</span></button>
            </div>
        </div>

        <!-- Tabs -->
        <div class="flex flex-wrap justify-center gap-3 mb-10 pb-4 border-b border-gray-100">
            <button onclick="showTab(0)" id="tab-0" class="tab-btn active px-6 py-3 text-lg font-bold rounded-xl text-gray-500 hover:text-sky-600 transition flex items-center gap-2">VPS Game Ninja School <span class="text-[10px] bg-amber-400 text-black px-2 py-1 rounded-md ml-1 shadow-sm uppercase tracking-wider">Đã MOD NSO</span></button>
            <button onclick="showTab(1)" id="tab-1" class="tab-btn px-6 py-3 text-lg font-bold rounded-xl text-gray-500 hover:text-sky-600 transition">VPS Trắng (Sạch sẽ)</button>
            <button onclick="showTab(2)" id="tab-2" class="tab-btn px-6 py-3 text-lg font-bold rounded-xl text-gray-500 hover:text-sky-600 transition">VPS Ngoại Proxy/IP</button>
        </div>

        <div id="content-0" class="tab-content grid md:grid-cols-3 lg:grid-cols-4 gap-6"></div>
        <div id="content-1" class="tab-content hidden grid md:grid-cols-3 lg:grid-cols-4 gap-6"></div>
        <div id="content-2" class="tab-content hidden grid md:grid-cols-3 lg:grid-cols-4 gap-6"></div>
    </section>

    <section id="quan-ly" class="bg-sky-50/50 py-24 border-y border-sky-100">
        <div class="max-w-5xl mx-auto px-6 text-center">
            <h2 class="text-4xl font-black text-gray-900 tracking-tight mb-4">Quản Lý VPS Tập Trung</h2>
            <p class="text-xl text-gray-500 font-medium mb-8">Theo dõi trạng thái dịch vụ, lịch sử giao dịch và gia hạn tự động ngay trong khu vực khách hàng.</p>
            <a href="<%=(typeof user!=='undefined'&&user)?'/user/vps':'/login'%>" class="inline-flex items-center justify-center bg-cyan-500 hover:bg-cyan-600 text-white px-8 py-4 rounded-2xl text-sm font-black uppercase tracking-wide transition shadow-lg shadow-cyan-500/25">
                Vào trang quản lý VPS
            </a>
        </div>
    </section>

    <!-- FOOTER -->
    <footer id="lien-he" class="bg-gray-900 text-white py-16">
        <div class="max-w-7xl mx-auto px-6">
            <div class="grid md:grid-cols-3 gap-12 text-center md:text-left mb-12">
                <div class="md:col-span-1 flex flex-col items-center md:items-start">
                  <div class="flex items-center gap-3 mb-6">
                      <div class="w-10 h-10 bg-gradient-to-br from-cyan-400 to-sky-600 rounded-xl flex items-center justify-center text-2xl rotate-12 ninja-icon font-bold">🥷</div>
                      <span class="logo-text text-3xl font-black">VPSphong</span>
                  </div>
                  <p class="text-sm font-medium text-gray-400 leading-relaxed mb-6">Chiến game thật phê, quản lý siêu dễ! Dịch vụ Cloud Server tối ưu hàng đầu tại Việt Nam.</p>
                </div>
                
                <div class="flex flex-col items-center md:items-start">
                  <h4 class="text-lg font-bold mb-6 text-white uppercase tracking-wider">Hỗ Trợ Nhanh</h4>
                  <a href="#" class="text-gray-400 hover:text-sky-400 font-medium mb-4 flex items-center gap-2 transition"><i class="fa-brands fa-facebook text-xl text-[#0866FF]"></i> Chat qua Facebook Fanpage</a>
                  <a href="#" class="text-gray-400 hover:text-sky-400 font-medium mb-4 flex items-center gap-2 transition"><i class="fa-solid fa-comment-dots text-xl text-[#0068FF]"></i> Liên hệ qua Zalo (5 phút rep)</a>
                </div>
                
                <div class="flex flex-col items-center md:items-start">
                  <h4 class="text-lg font-bold mb-6 text-white uppercase tracking-wider">Chính Sách</h4>
                  <a href="#" class="text-gray-400 hover:text-sky-400 font-medium mb-4 transition">Điều khoản sử dụng</a>
                  <a href="#" class="text-gray-400 hover:text-sky-400 font-medium mb-4 transition">Chính sách bảo mật</a>
                  <a href="#huong-dan" class="text-gray-400 hover:text-sky-400 font-medium mb-4 transition">Hướng dẫn sử dụng VPS</a>
                </div>
            </div>
            
            <div class="border-t border-gray-800 pt-8 text-center text-sm font-medium text-gray-500">
                © 2026 vpsphong.pro - Mọi bản quyền được bảo lưu.
            </div>
        </div>
    </footer>

    <style>
      .tab-btn.active { color: #0284c7; background-color: #f0f9ff; }
      .month-btn.active { background-color: #0284c7; color: white; }
    </style>

    <script>
        const serverPackages = <%- JSON.stringify(vpsPackages || []) %>;
        let currentMonth = 1;
        let selectedTab = 0;

        const packagesByTab = {
            0: serverPackages.filter(p => !p.productKind || p.productKind === 'game'),
            1: serverPackages.filter(p => p.productKind === 'blank'),
            2: serverPackages.filter(p => p.productKind === 'datacenter')
        };
        // Cập nhật fallback: Nếu gói VPS cũ không có productKind thì cứ nhét vô tab 0 hoặc 1

        function discountPrice(base, months) {
            let total = base * months;
            if (months === 3) total *= 0.9;
            if (months === 6) total *= 0.861;
            if (months === 12) total *= 0.833;
            return Math.floor(total);
        }

        function updateCardTotalPrice(cardId, unitBasePrice, months) {
            const qtyInput = document.getElementById(cardId + '-qty');
            const qtyLabel = document.getElementById(cardId + '-qty-label');
            const priceEl = document.getElementById(cardId + '-price');
            if (!qtyInput || !qtyLabel || !priceEl) return;

            let qty = parseInt(qtyInput.value, 10);
            if (!Number.isFinite(qty) || qty < 1) qty = 1;
            if (qtyInput.max && Number.isFinite(parseInt(qtyInput.max, 10))) {
                qty = Math.min(qty, parseInt(qtyInput.max, 10));
            }
            qtyInput.value = String(qty);
            qtyLabel.textContent = String(qty);

            const unitTotal = discountPrice(unitBasePrice, months);
            const total = unitTotal * qty;
            priceEl.textContent = Math.floor(total / 1000) + 'k';
        }

        function renderPlans() {
            const container = document.getElementById('content-' + selectedTab);
            container.innerHTML = '';
            const list = packagesByTab[selectedTab] || [];
            
            if(list.length === 0) {
                container.innerHTML = '<div class="col-span-full py-12 text-center border-2 border-dashed border-gray-200 rounded-3xl"><p class="text-gray-400 text-lg font-bold"><i class="fa-solid fa-box-open mr-2 text-2xl"></i>Danh mục này hiện chưa có gói cấu hình nào.</p></div>';
                return;
            }

            list.forEach((vps, i) => {
                const total = discountPrice(vps.price, currentMonth);
                const isLogged = <%= (typeof user !== 'undefined' && user) ? 'true' : 'false' %>;
                const cardId = `plan-${selectedTab}-${i}`;
                
                const formattedPrice = Math.floor(total / 1000) + 'k';
                const location = vps.ipLocation || 'Singapore';
                const bandwidthText = (vps.bandwidth === 0 || vps.bandwidth == null) ? 'Unlimited BW' : `${vps.bandwidth} Mbps`;
                const shortSpecsHtml = `
                    <p class="text-[11px] text-gray-500 font-bold mt-2 tracking-wide uppercase">${vps.cpu} Core • ${vps.ram}GB RAM • ${bandwidthText}</p>
                    <p class="text-[11px] text-gray-500 font-bold mt-1 tracking-wide uppercase">${vps.disk}GB SSD • IP ${location}</p>
                `;

                const escAttr = (s) => String(s)
                    .replace(/&/g, '&amp;')
                    .replace(/"/g, '&quot;')
                    .replace(/</g, '&lt;')
                    .replace(/>/g, '&gt;');
                let featuresHtml = '';
                if (vps.features && vps.features.length > 0) {
                    const opts = vps.features.map((f) =>
                        `<option value="${escAttr(f)}">${escAttr(f)}</option>`
                    ).join('');
                    featuresHtml = `
                        <div class="relative w-full">
                            <select
                                class="w-full bg-emerald-50/90 border border-emerald-200 text-emerald-800 text-[11px] font-bold py-3 pl-3 pr-9 rounded-xl outline-none focus:ring-2 focus:ring-emerald-400 cursor-pointer appearance-none text-left"
                                aria-label="Chọn hệ điều hành hoặc image"
                            >${opts}</select>
                            <span class="pointer-events-none absolute right-3 top-1/2 -translate-y-1/2 text-emerald-600 text-xs"><i class="fa-solid fa-chevron-down"></i></span>
                        </div>
                    `;
                } else {
                    featuresHtml = `
                        <p class="text-center text-[11px] font-bold text-gray-500 py-2">Cơ bản</p>
                    `;
                }

                const div = document.createElement('div');
                div.className = "bg-white flex flex-col border border-cyan-100/50 rounded-[2rem] p-7 text-center hover:border-cyan-400 hover:shadow-[0_10px_40px_-10px_rgba(0,188,212,0.3)] transition-all duration-300 relative group";
                
                const stockBadgeElement = vps.stock ? `<div class="absolute top-4 right-4 bg-emerald-100 text-emerald-700 text-xs font-bold px-2.5 py-1 rounded-full shadow-sm border border-emerald-200">Còn ${vps.stock}</div>` : '';

                div.innerHTML = `
                    ${stockBadgeElement}
                    <div class="mb-5">
                      <h3 class="text-xl font-bold text-gray-800 leading-tight">${vps.name}</h3>
                      ${shortSpecsHtml}
                    </div>
                    
                    <div class="my-3 flex justify-center items-end gap-1">
                      <span id="${cardId}-price" class="text-[2.75rem] font-black text-[#00a8cc] tracking-tighter leading-none">${formattedPrice}</span>
                      <span class="text-[13px] font-medium text-[#00a8cc] pb-1">/ ${currentMonth} tháng • x<span id="${cardId}-qty-label">1</span></span>
                    </div>
                    
                    <div class="flex flex-col flex-1 pt-6 pb-4 border-t border-dashed border-gray-100 mt-2 w-full px-1">
                        ${featuresHtml}
                    </div>
                    
                    <form action="/user/buy-vps" method="POST" class="mt-auto relative w-full">
                        <input type="hidden" name="vpsId" value="${vps._id}">
                        <input type="hidden" name="months" value="${currentMonth}">
                        <div class="px-2 mb-3">
                          <input
                            type="text"
                            name="voucherCode"
                            placeholder="Mã giảm giá (nếu có)"
                            class="w-full bg-gray-50 border border-gray-200 p-3 rounded-xl text-xs outline-none focus:ring-2 focus:ring-sky-400"
                          />
                        </div>
                        <div class="px-2 mb-3">
                          <label class="block text-[11px] font-bold text-gray-600 mb-1">Số lượng</label>
                          <input
                            type="number"
                            name="quantity"
                            id="${cardId}-qty"
                            min="1"
                            max="${vps.stock ? vps.stock : 1}"
                            step="1"
                            value="1"
                            oninput="updateCardTotalPrice('${cardId}', ${vps.price}, ${currentMonth})"
                            class="w-full bg-gray-50 border border-gray-200 p-3 rounded-xl text-xs outline-none focus:ring-2 focus:ring-sky-400"
                          />
                        </div>
                        ${isLogged ? `
                          <button type="submit" class="w-full bg-[#00a8cc] hover:bg-[#008ba8] text-white font-medium text-[13px] py-3.5 rounded-2xl transition-all duration-300 shadow-lg shadow-cyan-500/20">Thuê ngay</button>
                        ` : `
                          <a href="/login" class="flex items-center justify-center w-full bg-[#00a8cc] hover:bg-[#008ba8] text-white font-medium text-[13px] py-3.5 rounded-2xl transition-all duration-300 shadow-lg shadow-cyan-500/20">Thuê ngay</a>
                        `}
                    </form>
                `;
                container.appendChild(div);
            });
        }

        function setMonth(m) {
            currentMonth = m;
            document.querySelectorAll('.month-btn').forEach(btn => {
                btn.classList.remove('active', 'bg-sky-600', 'text-white');
                btn.classList.add('text-gray-600');
            });
            const selected = document.getElementById('month-' + m);
            selected.classList.add('active', 'bg-sky-600', 'text-white');
            selected.classList.remove('text-gray-600');
            renderPlans();
        }

        function showTab(n) {
            selectedTab = n;
            document.querySelectorAll('.tab-btn').forEach(b => {
                b.classList.remove('active', 'bg-sky-50', 'text-sky-600');
                b.classList.add('text-gray-500');
            });
            const t = document.getElementById('tab-' + n);
            t.classList.add('active', 'bg-sky-50', 'text-sky-600');
            t.classList.remove('text-gray-500');
            document.querySelectorAll('.tab-content').forEach(c => c.classList.add('hidden'));
            document.getElementById('content-' + n).classList.remove('hidden');
            renderPlans();
        }

        window.onload = () => {
            document.getElementById('tab-0').classList.add('active', 'bg-sky-50', 'text-sky-600');
            setMonth(1);
        };
    </script>

<%- include('partials/promo-modal', { promoModal: promoModal }) %>

</body>
</html>
