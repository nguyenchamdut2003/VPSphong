<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>VPS Phong</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
      body { background-color: #f8f9fa; font-family: 'Inter', sans-serif;}
      .navbar { box-shadow: 0 2px 4px rgba(0,0,0,.1); }
      .card { border-radius: 10px; border: none; box-shadow: 0 4px 6px rgba(0,0,0,.05); transition: transform 0.2s;}
      .card:hover { transform: translateY(-5px); }
    </style>
</head>
<body>
<nav class="navbar navbar-expand-lg navbar-dark bg-dark mb-4">
  <div class="container">
    <a class="navbar-brand fw-bold" href="/">🚀 VPS Phong</a>
    <div class="collapse navbar-collapse">
      <ul class="navbar-nav me-auto">
        <li class="nav-item"><a class="nav-link" href="/">Khám phá</a></li>
      </ul>
      <ul class="navbar-nav">
        <% if(typeof user !== 'undefined' && user) { %>
          <li class="nav-item"><a class="nav-link text-warning fw-bold">Số dư: <%= user.balance.toLocaleString() %> đ</a></li>
          <li class="nav-item">
             <a class="nav-link" href="<%=(user.role === 'admin') ? '/admin' : '/user/dashboard' %>">
               Quản lý (<%= user.username %>)
             </a>
          </li>
          <li class="nav-item"><a class="nav-link text-danger" href="/logout">Thoát</a></li>
        <% } else { %>
          <li class="nav-item"><a class="nav-link" href="/login">Đăng nhập</a></li>
          <li class="nav-item"><a class="nav-link" href="/register">Đăng ký</a></li>
        <% } %>
      </ul>
    </div>
  </div>
</nav>
<div class="container min-vh-100">
