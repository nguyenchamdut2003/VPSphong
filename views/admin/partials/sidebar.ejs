<style>
  .admin-sidebar-nav {
    scrollbar-width: thin;
    scrollbar-color: #4b5563 #111827;
  }
  .admin-sidebar-nav::-webkit-scrollbar { width: 6px; }
  .admin-sidebar-nav::-webkit-scrollbar-track { background: #111827; }
  .admin-sidebar-nav::-webkit-scrollbar-thumb { background: #4b5563; border-radius: 3px; }
  .admin-sidebar-nav::-webkit-scrollbar-thumb:hover { background: #6b7280; }
</style>
<aside class="w-64 bg-gray-900 text-white h-screen flex flex-col fixed shadow-xl z-20 overflow-hidden">
  <div class="shrink-0 px-6 py-5 bg-gray-800 text-xl font-bold tracking-widest text-center border-b border-gray-700">AdminPanel</div>
  <% const m = typeof activeMenu === 'string' ? activeMenu : ''; %>
  <% const b = (typeof adminBadges !== 'undefined' && adminBadges) ? adminBadges : {}; %>
  <% const badgeCount = (n) => {
    const v = Number(n) || 0;
    if (v < 1) return '';
    return v > 99 ? '99+' : String(v);
  }; %>
  <nav class="admin-sidebar-nav flex-1 min-h-0 overflow-y-auto mt-4 space-y-2 px-4 pb-4">
    <a href="/admin" class="flex items-center gap-3 px-4 py-3 rounded-lg <%= m === 'dashboard' ? 'bg-blue-600 text-white shadow-lg shadow-blue-500/30' : 'text-gray-400 hover:text-white hover:bg-gray-800 transition' %>">
      <i class="fa-solid fa-chart-pie w-5"></i> Tổng Quan
    </a>
    <a href="/admin/vps" class="flex items-center gap-3 px-4 py-3 rounded-lg <%= m === 'vps' ? 'bg-blue-600 text-white shadow-lg shadow-blue-500/30' : 'text-gray-400 hover:text-white hover:bg-gray-800 transition' %>">
      <i class="fa-solid fa-server w-5"></i> Quản Lý Dịch Vụ
    </a>
    <a href="/admin/upthue" class="flex items-center gap-3 px-4 py-3 rounded-lg <%= m === 'upthue' ? 'bg-blue-600 text-white shadow-lg shadow-blue-500/30' : 'text-gray-400 hover:text-white hover:bg-gray-800 transition' %>">
      <i class="fa-solid fa-user-ninja w-5 shrink-0"></i>
      <span class="flex-1">Quản lý Up thuê</span>
      <% if (badgeCount(b.upthue)) { %><span class="min-w-[1.35rem] h-5 px-1.5 flex items-center justify-center rounded-full bg-red-600 text-white text-[11px] font-extrabold leading-none"><%= badgeCount(b.upthue) %></span><% } %>
    </a>
    <a href="/admin/upthue/settings" class="flex items-center gap-3 px-4 py-3 rounded-lg ml-2 <%= m === 'upthue_settings' ? 'bg-violet-600 text-white shadow-lg shadow-violet-500/30' : 'text-gray-400 hover:text-white hover:bg-gray-800 transition' %>">
      <i class="fa-solid fa-sliders w-5 shrink-0"></i>
      <span class="flex-1 text-xs">Cấu hình Up thuê</span>
    </a>
    <a href="/user/up-thue" class="flex items-center gap-3 px-4 py-3 rounded-lg ml-2 <%= m === 'upthue_place' ? 'bg-violet-600 text-white shadow-lg shadow-violet-500/30' : 'text-gray-400 hover:text-white hover:bg-gray-800 transition' %>">
      <i class="fa-solid fa-cart-plus w-5 shrink-0"></i>
      <span class="flex-1 text-xs">Đặt Up thuê (0đ)</span>
    </a>
    <a href="/admin/fix-requests" class="flex items-center gap-3 px-4 py-3 rounded-lg <%= m === 'fix_requests' ? 'bg-blue-600 text-white shadow-lg shadow-blue-500/30' : 'text-gray-400 hover:text-white hover:bg-gray-800 transition' %>">
      <i class="fa-solid fa-screwdriver-wrench w-5 shrink-0"></i>
      <span class="flex-1">Đơn fix lỗi</span>
      <% if (badgeCount(b.fixRequests)) { %><span class="min-w-[1.35rem] h-5 px-1.5 flex items-center justify-center rounded-full bg-red-600 text-white text-[11px] font-extrabold leading-none"><%= badgeCount(b.fixRequests) %></span><% } %>
    </a>
    <a href="/admin/withdraw-requests" class="flex items-center gap-3 px-4 py-3 rounded-lg <%= m === 'withdraw_requests' ? 'bg-blue-600 text-white shadow-lg shadow-blue-500/30' : 'text-gray-400 hover:text-white hover:bg-gray-800 transition' %>">
      <i class="fa-solid fa-money-bill-transfer w-5 shrink-0"></i>
      <span class="flex-1">Đơn rút tiền</span>
      <% if (badgeCount(b.withdrawRequests)) { %><span class="min-w-[1.35rem] h-5 px-1.5 flex items-center justify-center rounded-full bg-red-600 text-white text-[11px] font-extrabold leading-none"><%= badgeCount(b.withdrawRequests) %></span><% } %>
    </a>
    <a href="/admin/backups" class="flex items-center gap-3 px-4 py-3 rounded-lg <%= m === 'backups' ? 'bg-blue-600 text-white shadow-lg shadow-blue-500/30' : 'text-gray-400 hover:text-white hover:bg-gray-800 transition' %>">
      <i class="fa-solid fa-database w-5"></i> Backup dữ liệu
    </a>
    <a href="/admin/vouchers" class="flex items-center gap-3 px-4 py-3 rounded-lg <%= m === 'vouchers' ? 'bg-blue-600 text-white shadow-lg shadow-blue-500/30' : 'text-gray-400 hover:text-white hover:bg-gray-800 transition' %>">
      <i class="fa-solid fa-ticket w-5"></i> Voucher
    </a>
    <a href="/admin/users" class="flex items-center gap-3 px-4 py-3 rounded-lg <%= m === 'users' ? 'bg-blue-600 text-white shadow-lg shadow-blue-500/30' : 'text-gray-400 hover:text-white hover:bg-gray-800 transition' %>">
      <i class="fa-solid fa-users w-5"></i> Danh sách Khách
    </a>
    <a href="/admin/logs" class="flex items-center gap-3 px-4 py-3 rounded-lg <%= m === 'logs' ? 'bg-blue-600 text-white shadow-lg shadow-blue-500/30' : 'text-gray-400 hover:text-white hover:bg-gray-800 transition' %>">
      <i class="fa-solid fa-clock-rotate-left w-5 shrink-0"></i>
      <span class="flex-1">Báo cáo Log</span>
      <% if (badgeCount(b.logs)) { %><span class="min-w-[1.35rem] h-5 px-1.5 flex items-center justify-center rounded-full bg-red-600 text-white text-[11px] font-extrabold leading-none"><%= badgeCount(b.logs) %></span><% } %>
    </a>
    <a href="/admin/settings/support" class="flex items-center gap-3 px-4 py-3 rounded-lg <%= m === 'settings_support' ? 'bg-blue-600 text-white shadow-lg shadow-blue-500/30' : 'text-gray-400 hover:text-white hover:bg-gray-800 transition' %>">
      <i class="fa-solid fa-headset w-5"></i> Liên hệ hỗ trợ
    </a>
    <a href="/admin/settings/promo-modal" class="flex items-center gap-3 px-4 py-3 rounded-lg <%= m === 'settings_promo_modal' ? 'bg-blue-600 text-white shadow-lg shadow-blue-500/30' : 'text-gray-400 hover:text-white hover:bg-gray-800 transition' %>">
      <i class="fa-solid fa-bullhorn w-5"></i> Modal Quảng Cáo
    </a>
  </nav>
  <div class="shrink-0 p-4 border-t border-gray-800 bg-gray-900">
    <a href="/" class="block w-full py-3 text-center bg-gray-800 hover:bg-gray-700 text-gray-300 font-medium rounded-xl transition"><i class="fa-solid fa-house"></i> Về Website</a>
  </div>
</aside>
