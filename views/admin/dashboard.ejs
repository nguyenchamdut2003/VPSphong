<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <title>Thống Kê - VPS Phong Admin</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.6.0/css/all.min.css">
  <style>body { font-family: 'Inter', system-ui, sans-serif; background-color: #f3f4f6; }</style>
</head>
<body class="flex min-h-screen text-sm">

  <!-- Sidebar -->
  <aside class="w-64 bg-gray-900 text-white min-h-screen flex flex-col fixed shadow-xl z-20">
    <div class="px-6 py-5 bg-gray-800 text-xl font-bold tracking-widest text-center border-b border-gray-700">AdminPanel</div>
    <nav class="flex-1 mt-6 space-y-2 px-4">
      <a href="/admin" class="flex items-center gap-3 px-4 py-3 rounded-lg bg-blue-600 text-white shadow-lg shadow-blue-500/30">
        <i class="fa-solid fa-chart-pie w-5"></i> Tổng Quan
      </a>
      <a href="/admin/vps" class="flex items-center gap-3 px-4 py-3 rounded-lg text-gray-400 hover:text-white hover:bg-gray-800 transition">
        <i class="fa-solid fa-server w-5"></i> Quản Lý Dịch Vụ
      </a>
      <a href="/admin/vouchers" class="flex items-center gap-3 px-4 py-3 rounded-lg text-gray-400 hover:text-white hover:bg-gray-800 transition">
        <i class="fa-solid fa-ticket w-5"></i> Voucher
      </a>
      <a href="/admin/users" class="flex items-center gap-3 px-4 py-3 rounded-lg text-gray-400 hover:text-white hover:bg-gray-800 transition">
        <i class="fa-solid fa-users w-5"></i> Danh sách Khách
      </a>
      <a href="/admin/logs" class="flex items-center gap-3 px-4 py-3 rounded-lg text-gray-400 hover:text-white hover:bg-gray-800 transition">
        <i class="fa-solid fa-clock-rotate-left w-5"></i> Báo cáo Log
      </a>
      <a href="/admin/settings/support" class="flex items-center gap-3 px-4 py-3 rounded-lg text-gray-400 hover:text-white hover:bg-gray-800 transition">
        <i class="fa-solid fa-headset w-5"></i> Liên hệ hỗ trợ
      </a>
    </nav>
    <div class="p-6">
      <a href="/" class="block w-full py-3 text-center bg-gray-800 hover:bg-gray-700 text-gray-300 font-medium rounded-xl transition"><i class="fa-solid fa-house"></i> Về Website</a>
    </div>
  </aside>

  <!-- Main content -->
  <main class="flex-1 ml-64 flex flex-col min-h-screen">
    <header class="bg-white h-16 border-b flex items-center justify-between px-8 shadow-sm">
      <div class="font-bold text-gray-800 text-lg">Bảng Điều Khiển Lãnh Đạo</div>
      <div class="flex items-center gap-5">
         <span class="font-bold text-gray-900 px-3 py-1 bg-gray-100 rounded-lg"><i class="fa-solid fa-shield-halved text-blue-500 mr-2"></i><%= typeof admin !== 'undefined' ? admin.username : 'Admin' %></span>
         <a href="/logout" class="text-red-500 hover:text-red-700 font-bold"><i class="fa-solid fa-right-from-bracket"></i> Đăng Xuất</a>
      </div>
    </header>

    <div class="p-8 flex-1">
      <h2 class="text-2xl font-extrabold text-gray-800 mb-6 border-l-4 border-blue-500 pl-3">Báo cáo Mới nhất</h2>
      <div class="grid grid-cols-2 gap-6 mb-8">
        <div class="bg-white p-6 rounded-2xl border border-gray-100 shadow-sm flex items-center gap-5 hover:shadow-lg transition">
          <div class="w-16 h-16 bg-blue-50 text-blue-600 rounded-2xl flex items-center justify-center text-3xl"><i class="fa-solid fa-users"></i></div>
          <div><p class="text-gray-500 font-semibold mb-1 text-sm uppercase tracking-wide">Tài khoản Đã Mở</p><p class="text-4xl font-extrabold text-gray-900"><%= totalUsers %></p></div>
        </div>
        <div class="bg-white p-6 rounded-2xl border border-gray-100 shadow-sm flex items-center gap-5 hover:shadow-lg transition">
          <div class="w-16 h-16 bg-emerald-50 text-emerald-600 rounded-2xl flex items-center justify-center text-3xl"><i class="fa-solid fa-server"></i></div>
          <div><p class="text-gray-500 font-semibold mb-1 text-sm uppercase tracking-wide">Số Container Đang Chạy</p><p class="text-4xl font-extrabold text-gray-900"><%= totalVpsSold %></p></div>
        </div>
      </div>
    </div>
  </main>
</body>
</html>
