<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <title>Thống Kê - VPS Phong Admin</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.6.0/css/all.min.css">
  <style>body { font-family: 'Inter', system-ui, sans-serif; background-color: #f3f4f6; }</style>
</head>
<body class="flex min-h-screen text-sm">

  <%- include('partials/sidebar', { activeMenu: 'dashboard' }) %>

  <!-- Main content -->
  <main class="flex-1 ml-64 flex flex-col min-h-screen">
    <header class="bg-white h-16 border-b flex items-center justify-between px-8 shadow-sm">
      <div class="font-bold text-gray-800 text-lg">Bảng Điều Khiển Lãnh Đạo</div>
      <div class="flex items-center gap-5">
         <span class="font-bold text-gray-900 px-3 py-1 bg-gray-100 rounded-lg"><i class="fa-solid fa-shield-halved text-blue-500 mr-2"></i><%= typeof admin !== 'undefined' ? admin.username : 'Admin' %></span>
         <a href="/logout" class="text-red-500 hover:text-red-700 font-bold"><i class="fa-solid fa-right-from-bracket"></i> Đăng Xuất</a>
      </div>
    </header>

    <div class="p-8 flex-1">
      <% const _money = (v) => {
        if (typeof v === 'undefined' || v === null) return 0;
        const n = Number(v);
        return Number.isNaN(n) ? 0 : n;
      }; %>
      <h2 class="text-2xl font-extrabold text-gray-800 mb-6 border-l-4 border-blue-500 pl-3">Báo cáo Mới nhất</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-6 mb-8">
        <div class="bg-white p-6 rounded-2xl border border-gray-100 shadow-sm flex items-center gap-5 hover:shadow-lg transition">
          <div class="w-16 h-16 bg-blue-50 text-blue-600 rounded-2xl flex items-center justify-center text-3xl"><i class="fa-solid fa-users"></i></div>
          <div><p class="text-gray-500 font-semibold mb-1 text-sm uppercase tracking-wide">Tài khoản Đã Mở</p><p class="text-4xl font-extrabold text-gray-900"><%= totalUsers %></p></div>
        </div>
        <div class="bg-white p-6 rounded-2xl border border-gray-100 shadow-sm flex items-center gap-5 hover:shadow-lg transition">
          <div class="w-16 h-16 bg-emerald-50 text-emerald-600 rounded-2xl flex items-center justify-center text-3xl"><i class="fa-solid fa-bag-shopping"></i></div>
          <div><p class="text-gray-500 font-semibold mb-1 text-sm uppercase tracking-wide">VPS đã bán</p><p class="text-4xl font-extrabold text-gray-900"><%= totalVpsSold %></p></div>
        </div>
        <div class="bg-white p-6 rounded-2xl border border-gray-100 shadow-sm flex items-center gap-5 hover:shadow-lg transition">
          <div class="w-16 h-16 bg-cyan-50 text-cyan-600 rounded-2xl flex items-center justify-center text-3xl"><i class="fa-solid fa-box-open"></i></div>
          <div><p class="text-gray-500 font-semibold mb-1 text-sm uppercase tracking-wide">VPS còn lại</p><p class="text-4xl font-extrabold text-gray-900"><%= totalVpsAvailable %></p></div>
        </div>
        <div class="bg-white p-6 rounded-2xl border border-gray-100 shadow-sm flex items-center gap-5 hover:shadow-lg transition">
          <div class="w-16 h-16 bg-lime-50 text-lime-600 rounded-2xl flex items-center justify-center text-3xl"><i class="fa-solid fa-power-off"></i></div>
          <div><p class="text-gray-500 font-semibold mb-1 text-sm uppercase tracking-wide">VPS đang chạy</p><p class="text-4xl font-extrabold text-gray-900"><%= totalVpsRunning %></p></div>
        </div>
        <div class="bg-white p-6 rounded-2xl border border-gray-100 shadow-sm flex items-center gap-5 hover:shadow-lg transition">
          <div class="w-16 h-16 bg-amber-50 text-amber-600 rounded-2xl flex items-center justify-center text-3xl"><i class="fa-solid fa-screwdriver-wrench"></i></div>
          <div><p class="text-gray-500 font-semibold mb-1 text-sm uppercase tracking-wide">Số lần đã fix</p><p class="text-4xl font-extrabold text-gray-900"><%= totalFixResolved %></p></div>
        </div>
        <div class="bg-white p-6 rounded-2xl border border-gray-100 shadow-sm flex items-center gap-5 hover:shadow-lg transition">
          <div class="w-16 h-16 bg-sky-50 text-sky-600 rounded-2xl flex items-center justify-center text-3xl"><i class="fa-solid fa-wallet"></i></div>
          <div><p class="text-gray-500 font-semibold mb-1 text-sm uppercase tracking-wide">Tiền khách chưa dùng</p><p class="text-2xl font-extrabold text-gray-900"><%= _money(totalCustomerBalance).toLocaleString() %>đ</p></div>
        </div>
        <div class="bg-white p-6 rounded-2xl border border-gray-100 shadow-sm flex items-center gap-5 hover:shadow-lg transition">
          <div class="w-16 h-16 bg-rose-50 text-rose-600 rounded-2xl flex items-center justify-center text-3xl"><i class="fa-solid fa-money-bill-trend-up"></i></div>
          <div><p class="text-gray-500 font-semibold mb-1 text-sm uppercase tracking-wide">Tổng khách đã sử dụng</p><p class="text-2xl font-extrabold text-gray-900"><%= _money(totalCustomerUsed).toLocaleString() %>đ</p></div>
        </div>
      </div>
    </div>
  </main>
</body>
</html>
