<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <title>Hỗ trợ khách - Admin</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.6.0/css/all.min.css">
  <style>body { font-family: 'Inter', system-ui, sans-serif; background-color: #f3f4f6; }</style>
</head>
<body class="flex min-h-screen text-sm">

  <aside class="w-64 bg-gray-900 text-white min-h-screen flex flex-col fixed shadow-xl z-20">
    <div class="px-6 py-5 bg-gray-800 text-xl font-bold tracking-widest text-center border-b border-gray-700">AdminPanel</div>
    <nav class="flex-1 mt-6 space-y-2 px-4">
      <a href="/admin" class="flex items-center gap-3 px-4 py-3 rounded-lg text-gray-400 hover:text-white hover:bg-gray-800 transition">
        <i class="fa-solid fa-chart-pie w-5"></i> Tổng Quan
      </a>
      <a href="/admin/vps" class="flex items-center gap-3 px-4 py-3 rounded-lg text-gray-400 hover:text-white hover:bg-gray-800 transition">
        <i class="fa-solid fa-server w-5"></i> Quản Lý Dịch Vụ
      </a>
      <a href="/admin/fix-requests" class="flex items-center gap-3 px-4 py-3 rounded-lg text-gray-400 hover:text-white hover:bg-gray-800 transition">
        <i class="fa-solid fa-screwdriver-wrench w-5"></i> Đơn fix lỗi
      </a>
      <a href="/admin/vouchers" class="flex items-center gap-3 px-4 py-3 rounded-lg text-gray-400 hover:text-white hover:bg-gray-800 transition">
        <i class="fa-solid fa-ticket w-5"></i> Voucher
      </a>
      <a href="/admin/users" class="flex items-center gap-3 px-4 py-3 rounded-lg text-gray-400 hover:text-white hover:bg-gray-800 transition">
        <i class="fa-solid fa-users w-5"></i> Danh sách Khách
      </a>
      <a href="/admin/logs" class="flex items-center gap-3 px-4 py-3 rounded-lg text-gray-400 hover:text-white hover:bg-gray-800 transition">
        <i class="fa-solid fa-clock-rotate-left w-5"></i> Báo cáo Log
      </a>
      <a href="/admin/settings/support" class="flex items-center gap-3 px-4 py-3 rounded-lg bg-indigo-600 text-white shadow-lg shadow-indigo-500/30">
        <i class="fa-solid fa-headset w-5"></i> Liên hệ hỗ trợ
      </a>
      <a href="/admin/settings/promo-modal" class="flex items-center gap-3 px-4 py-3 rounded-lg text-gray-400 hover:text-white hover:bg-gray-800 transition">
        <i class="fa-solid fa-bullhorn w-5"></i> Modal Quảng Cáo
      </a>
    </nav>
    <div class="p-6">
      <a href="/" class="block w-full py-3 text-center bg-gray-800 hover:bg-gray-700 text-gray-300 font-medium rounded-xl transition"><i class="fa-solid fa-house"></i> Về Website</a>
    </div>
  </aside>

  <main class="flex-1 ml-64 flex flex-col min-h-screen">
    <header class="bg-white h-16 border-b flex items-center justify-between px-8 shadow-sm">
      <div class="font-bold text-gray-800 text-lg border-l-4 border-indigo-500 pl-3">Liên hệ hỗ trợ (Zalo / Facebook)</div>
      <div class="flex items-center gap-5">
        <span class="font-bold text-gray-900 px-3 py-1 bg-gray-100 rounded-lg"><i class="fa-solid fa-shield-halved text-blue-500 mr-2"></i><%= admin.username %></span>
        <a href="/logout" class="text-red-500 hover:text-red-700 font-bold">Đăng Xuất</a>
      </div>
    </header>

    <div class="p-8 flex-1">
      <% if (typeof saved !== 'undefined' && saved) { %>
      <div class="mb-6 p-4 rounded-xl bg-emerald-50 border border-emerald-200 text-emerald-800 font-semibold">Đã lưu. Khách sẽ thấy nút hỗ trợ bên phải dashboard nếu có ít nhất một link.</div>
      <% } %>

      <div class="max-w-2xl bg-white rounded-2xl shadow-sm border border-gray-100 p-8">
        <p class="text-gray-500 text-sm mb-6">Dán link nhóm Zalo, trang Facebook hoặc chat trực tiếp. Để trống nếu chưa dùng — icon tương ứng sẽ ẩn trên giao diện khách.</p>
        <form action="/admin/settings/support" method="POST" class="space-y-5">
          <div>
            <label class="block text-xs font-bold text-gray-500 uppercase mb-2">Link Zalo (nhóm / OA / cá nhân)</label>
            <input type="url" name="supportZaloUrl" value="<%= settings.supportZaloUrl || '' %>" placeholder="https://zalo.me/g/..." class="w-full border border-gray-200 rounded-xl px-4 py-3 text-sm outline-none focus:ring-2 focus:ring-indigo-500/30">
          </div>
          <div>
            <label class="block text-xs font-bold text-gray-500 uppercase mb-2">Link Facebook</label>
            <input type="url" name="supportFacebookUrl" value="<%= settings.supportFacebookUrl || '' %>" placeholder="https://facebook.com/..." class="w-full border border-gray-200 rounded-xl px-4 py-3 text-sm outline-none focus:ring-2 focus:ring-indigo-500/30">
          </div>
          <button type="submit" class="px-8 py-3 rounded-xl bg-gray-900 text-white font-bold hover:bg-indigo-600 transition">Lưu cấu hình</button>
        </form>
      </div>
    </div>
  </main>
</body>
</html>
