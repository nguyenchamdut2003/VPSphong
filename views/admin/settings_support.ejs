<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <title>Hỗ trợ khách - Admin</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.6.0/css/all.min.css">
  <style>body { font-family: 'Inter', system-ui, sans-serif; background-color: #f3f4f6; }</style>
</head>
<body class="flex min-h-screen text-sm">

  <%- include('partials/sidebar', { activeMenu: 'settings_support' }) %>

  <main class="flex-1 ml-64 flex flex-col min-h-screen">
    <header class="bg-white h-16 border-b flex items-center justify-between px-8 shadow-sm">
      <div class="font-bold text-gray-800 text-lg border-l-4 border-indigo-500 pl-3">Liên hệ hỗ trợ (Zalo / Facebook)</div>
      <div class="flex items-center gap-5">
        <span class="font-bold text-gray-900 px-3 py-1 bg-gray-100 rounded-lg"><i class="fa-solid fa-shield-halved text-blue-500 mr-2"></i><%= admin.username %></span>
        <a href="/logout" class="text-red-500 hover:text-red-700 font-bold">Đăng Xuất</a>
      </div>
    </header>

    <div class="p-8 flex-1">
      <% if (typeof saved !== 'undefined' && saved) { %>
      <div class="mb-6 p-4 rounded-xl bg-emerald-50 border border-emerald-200 text-emerald-800 font-semibold">Đã lưu. Khách sẽ thấy nút hỗ trợ bên phải dashboard nếu có ít nhất một link.</div>
      <% } %>

      <div class="max-w-2xl bg-white rounded-2xl shadow-sm border border-gray-100 p-8">
        <p class="text-gray-500 text-sm mb-6">Dán link nhóm Zalo, trang Facebook hoặc chat trực tiếp. Để trống nếu chưa dùng — icon tương ứng sẽ ẩn trên giao diện khách.</p>
        <form action="/admin/settings/support" method="POST" class="space-y-5">
          <div>
            <label class="block text-xs font-bold text-gray-500 uppercase mb-2">Link Zalo (nhóm / OA / cá nhân)</label>
            <input type="url" name="supportZaloUrl" value="<%= settings.supportZaloUrl || '' %>" placeholder="https://zalo.me/g/..." class="w-full border border-gray-200 rounded-xl px-4 py-3 text-sm outline-none focus:ring-2 focus:ring-indigo-500/30">
          </div>
          <div>
            <label class="block text-xs font-bold text-gray-500 uppercase mb-2">Link Facebook</label>
            <input type="url" name="supportFacebookUrl" value="<%= settings.supportFacebookUrl || '' %>" placeholder="https://facebook.com/..." class="w-full border border-gray-200 rounded-xl px-4 py-3 text-sm outline-none focus:ring-2 focus:ring-indigo-500/30">
          </div>
          <button type="submit" class="px-8 py-3 rounded-xl bg-gray-900 text-white font-bold hover:bg-indigo-600 transition">Lưu cấu hình</button>
        </form>
      </div>
    </div>
  </main>
</body>
</html>
