<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <title>Đơn Fix Lỗi - Admin</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.6.0/css/all.min.css">
  <style>body { font-family: 'Inter', system-ui, sans-serif; background-color: #f3f4f6; }</style>
</head>
<body class="flex min-h-screen text-sm">
  <aside class="w-64 bg-gray-900 text-white min-h-screen flex flex-col fixed shadow-xl z-20">
    <div class="px-6 py-5 bg-gray-800 text-xl font-bold tracking-widest text-center border-b border-gray-700">AdminPanel</div>
    <nav class="flex-1 mt-6 space-y-2 px-4">
      <a href="/admin" class="flex items-center gap-3 px-4 py-3 rounded-lg text-gray-400 hover:text-white hover:bg-gray-800 transition"><i class="fa-solid fa-chart-pie w-5"></i> Tổng Quan</a>
      <a href="/admin/vps" class="flex items-center gap-3 px-4 py-3 rounded-lg text-gray-400 hover:text-white hover:bg-gray-800 transition"><i class="fa-solid fa-server w-5"></i> Quản Lý Dịch Vụ</a>
      <a href="/admin/fix-requests" class="flex items-center gap-3 px-4 py-3 rounded-lg bg-blue-600 text-white shadow-lg shadow-blue-500/30"><i class="fa-solid fa-screwdriver-wrench w-5"></i> Đơn fix lỗi</a>
      <a href="/admin/vouchers" class="flex items-center gap-3 px-4 py-3 rounded-lg text-gray-400 hover:text-white hover:bg-gray-800 transition"><i class="fa-solid fa-ticket w-5"></i> Voucher</a>
      <a href="/admin/users" class="flex items-center gap-3 px-4 py-3 rounded-lg text-gray-400 hover:text-white hover:bg-gray-800 transition"><i class="fa-solid fa-users w-5"></i> Danh sách Khách</a>
      <a href="/admin/logs" class="flex items-center gap-3 px-4 py-3 rounded-lg text-gray-400 hover:text-white hover:bg-gray-800 transition"><i class="fa-solid fa-clock-rotate-left w-5"></i> Báo cáo Log</a>
      <a href="/admin/settings/support" class="flex items-center gap-3 px-4 py-3 rounded-lg text-gray-400 hover:text-white hover:bg-gray-800 transition"><i class="fa-solid fa-headset w-5"></i> Liên hệ hỗ trợ</a>
    </nav>
    <div class="p-6">
      <a href="/" class="block w-full py-3 text-center bg-gray-800 hover:bg-gray-700 text-gray-300 font-medium rounded-xl transition"><i class="fa-solid fa-house"></i> Về Website</a>
    </div>
  </aside>

  <main class="flex-1 ml-64 p-8">
    <div class="mb-6 flex items-center justify-between">
      <h1 class="text-2xl font-black text-gray-900">Danh sách đơn fix lỗi VPS</h1>
      <span class="px-3 py-2 rounded-lg bg-blue-50 text-blue-700 font-bold">Đang chờ: <%= (list || []).length %></span>
    </div>

    <div class="bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden">
      <table class="w-full text-left border-collapse text-xs md:text-sm">
        <thead class="bg-gray-50 text-gray-500 uppercase tracking-wider border-b border-gray-200">
          <tr>
            <th class="px-4 py-4 font-bold">Khách hàng</th>
            <th class="px-4 py-4 font-bold">VPS</th>
            <th class="px-4 py-4 font-bold">IP</th>
            <th class="px-4 py-4 font-bold">Yêu cầu</th>
            <th class="px-4 py-4 font-bold">Thời gian gửi</th>
            <th class="px-4 py-4 font-bold">Xử lý</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100 text-gray-800">
          <% (list || []).forEach(item => { %>
            <% const vpsCode = (item.vpsId && typeof item.vpsId.saleCode === 'number' && item.vpsId.saleCode > 0) ? ('#vpsphong' + item.vpsId.saleCode) : ('#vpsphong' + String(item._id).slice(-6)); %>
            <% const act = item.pendingPowerAction || 'unknown'; %>
            <% const actLabel = act === 'restart' ? 'Restart' : (act === 'stop' ? 'Stop' : (act === 'start' ? 'Start' : act)); %>
            <tr class="hover:bg-gray-50 transition">
              <td class="px-4 py-4">
                <div class="font-bold text-gray-900"><%= item.userId ? item.userId.username : '—' %></div>
                <div class="text-gray-500"><%= item.userId ? item.userId.email : '' %></div>
              </td>
              <td class="px-4 py-4 font-semibold text-blue-700">
                <%= item.vpsId ? item.vpsId.name : 'VPS' %> <span class="font-mono"><%= vpsCode %></span>
              </td>
              <td class="px-4 py-4 font-mono"><%= item.ip || (item.vpsId ? item.vpsId.serverIp : '—') || '—' %></td>
              <td class="px-4 py-4">
                <span class="px-2 py-1 rounded-md text-xs font-bold bg-amber-100 text-amber-700"><%= actLabel %></span>
              </td>
              <td class="px-4 py-4 text-gray-600"><%= item.powerActionRequestedAt ? new Date(item.powerActionRequestedAt).toLocaleString('vi-VN') : '—' %></td>
              <td class="px-4 py-4">
                <form action="/admin/fix-requests/<%= item._id %>/resolve" method="POST" onsubmit="return confirm('Xác nhận đã xử lý xong yêu cầu này?');">
                  <button type="submit" class="px-3 py-2 rounded-lg text-xs font-bold border border-emerald-200 text-emerald-700 hover:bg-emerald-50">OK - Hoàn thành</button>
                </form>
              </td>
            </tr>
          <% }) %>
          <% if (!(list || []).length) { %>
            <tr><td colspan="6" class="text-center py-10 text-gray-400 font-medium">Hiện chưa có yêu cầu fix lỗi nào đang chờ.</td></tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </main>
</body>
</html>
