<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <title>Sửa VPS - Admin</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.6.0/css/all.min.css">
  <style>body { font-family: 'Inter', system-ui, sans-serif; background-color: #f3f4f6; }</style>
</head>
<body class="flex min-h-screen text-sm">
  <%- include('partials/sidebar', { activeMenu: 'vps' }) %>

  <main class="flex-1 ml-64 p-8">
    <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-6">
      <div class="flex items-center justify-between mb-5">
        <h1 class="text-xl font-black text-gray-900">Sửa VPS <span class="text-blue-700">#vpsphong<%= vps.saleCode || String(vps._id).slice(-6) %></span></h1>
        <a href="/admin/vps" class="px-4 py-2 rounded-lg bg-gray-100 hover:bg-gray-200 font-bold">Quay lại</a>
      </div>
      <% if (error) { %><div class="mb-4 p-3 rounded-lg bg-red-50 border border-red-200 text-red-700 font-semibold"><%= error %></div><% } %>

      <form action="/admin/vps/<%= vps._id %>/update" method="POST" class="grid grid-cols-1 md:grid-cols-12 gap-5">
        <div class="md:col-span-6">
          <label class="block text-xs font-bold text-gray-500 uppercase mb-2">Loại VPS</label>
          <select name="categoryId" class="w-full bg-gray-50 border border-gray-200 p-3 rounded-xl font-semibold" required>
            <% (categories || []).forEach(c => { %>
              <option value="<%= c._id %>" <%= String(vps.categoryId) === String(c._id) ? 'selected' : '' %>><%= c.name %></option>
            <% }) %>
          </select>
        </div>
        <div class="md:col-span-6">
          <label class="block text-xs font-bold text-gray-500 uppercase mb-2">Giá (VNĐ)</label>
          <input type="number" name="price" min="0" step="1000" value="<%= vps.price || 0 %>" class="w-full bg-blue-50 border border-blue-200 p-3 rounded-xl font-bold text-blue-800" required>
        </div>

        <div class="md:col-span-12">
          <label class="block text-xs font-bold text-gray-500 uppercase mb-2">Kiểu gói</label>
          <select name="productKind" class="w-full bg-gray-50 border border-gray-200 p-3 rounded-xl font-semibold" required>
            <option value="game" <%= vps.productKind === 'game' ? 'selected' : '' %>>Treo game</option>
            <option value="blank" <%= !vps.productKind || vps.productKind === 'blank' ? 'selected' : '' %>>VPS trắng</option>
            <option value="datacenter" <%= vps.productKind === 'datacenter' ? 'selected' : '' %>>Datacenter</option>
          </select>
        </div>

        <div class="md:col-span-2"><label class="block text-xs font-bold text-gray-500 uppercase mb-2">CPU</label><input type="number" name="cpu" min="1" max="256" value="<%= vps.cpu || 1 %>" class="w-full bg-gray-50 border border-gray-200 p-3 rounded-xl" required></div>
        <div class="md:col-span-2"><label class="block text-xs font-bold text-gray-500 uppercase mb-2">RAM</label><input type="number" name="ram" min="1" max="1024" value="<%= vps.ram || 1 %>" class="w-full bg-gray-50 border border-gray-200 p-3 rounded-xl" required></div>
        <div class="md:col-span-2"><label class="block text-xs font-bold text-gray-500 uppercase mb-2">SSD</label><input type="number" name="disk" min="1" max="10000" value="<%= vps.disk || 1000 %>" class="w-full bg-gray-50 border border-gray-200 p-3 rounded-xl" required></div>
        <div class="md:col-span-2"><label class="block text-xs font-bold text-gray-500 uppercase mb-2">Băng thông</label><input type="number" name="bandwidth" min="0" step="1" value="<%= (vps.bandwidth != null ? vps.bandwidth : '') %>" class="w-full bg-gray-50 border border-gray-200 p-3 rounded-xl"></div>
        <div class="md:col-span-4"><label class="block text-xs font-bold text-gray-500 uppercase mb-2">Chu kỳ gia hạn</label><input type="number" name="billingCycleDays" min="1" max="365" value="<%= vps.billingCycleDays || 30 %>" class="w-full bg-gray-50 border border-gray-200 p-3 rounded-xl"></div>

        <div class="md:col-span-4"><label class="block text-xs font-bold text-gray-500 uppercase mb-2">IP máy chủ</label><input type="text" name="serverIp" value="<%= vps.serverIp || '' %>" class="w-full bg-amber-50 border border-amber-200 p-3 rounded-xl font-mono" required></div>
        <div class="md:col-span-4"><label class="block text-xs font-bold text-gray-500 uppercase mb-2">User SSH</label><input type="text" name="serverUsername" value="<%= vps.serverUsername || 'root' %>" class="w-full bg-gray-50 border border-gray-200 p-3 rounded-xl font-mono"></div>
        <div class="md:col-span-4"><label class="block text-xs font-bold text-gray-500 uppercase mb-2">Mật khẩu mới (để trống nếu giữ nguyên)</label><input type="text" name="serverPassword" value="" class="w-full bg-gray-50 border border-gray-200 p-3 rounded-xl font-mono"></div>

        <div class="md:col-span-12 border-t border-gray-100 pt-4">
          <p class="text-xs font-bold text-gray-500 uppercase mb-2">Thời gian thuê lần đầu</p>
          <div class="flex flex-wrap gap-6 mb-3">
            <label class="inline-flex items-center gap-2 font-semibold text-gray-700"><input type="radio" name="durationKind" value="days" class="accent-blue-600" <%= vps.durationKind !== 'until_date' ? 'checked' : '' %> onchange="toggleDuration()">Theo số ngày</label>
            <label class="inline-flex items-center gap-2 font-semibold text-gray-700"><input type="radio" name="durationKind" value="until_date" class="accent-blue-600" <%= vps.durationKind === 'until_date' ? 'checked' : '' %> onchange="toggleDuration()">Đến ngày cố định</label>
          </div>
          <div class="grid md:grid-cols-12 gap-4">
            <div class="md:col-span-4 <%= vps.durationKind === 'until_date' ? 'hidden' : '' %>" id="wrap-days">
              <label class="block text-xs font-bold text-gray-500 uppercase mb-2">Số ngày thuê đầu tiên</label>
              <input type="number" name="initialRentDays" min="1" max="3650" value="<%= vps.initialRentDays || 30 %>" class="w-full bg-gray-50 border border-gray-200 p-3 rounded-xl">
            </div>
            <div class="md:col-span-4 <%= vps.durationKind === 'until_date' ? '' : 'hidden' %>" id="wrap-until">
              <label class="block text-xs font-bold text-gray-500 uppercase mb-2">Hết hạn vào ngày</label>
              <input type="date" name="rentValidUntil" value="<%= vps.rentValidUntil ? new Date(vps.rentValidUntil).toISOString().slice(0,10) : '' %>" class="w-full bg-gray-50 border border-gray-200 p-3 rounded-xl">
            </div>
          </div>
        </div>

        <div class="md:col-span-4"><label class="block text-xs font-bold text-gray-500 uppercase mb-2">Vị trí IP</label><input type="text" name="ipLocation" value="<%= vps.ipLocation || 'Singapore' %>" class="w-full bg-blue-50 border border-blue-200 p-3 rounded-xl"></div>
        <div class="md:col-span-8">
          <label class="block text-xs font-bold text-gray-500 uppercase mb-2">Tính năng</label>
          <div class="bg-gray-50 border border-gray-200 rounded-xl p-4 mb-2 max-h-40 overflow-y-auto">
            <div class="grid grid-cols-2 lg:grid-cols-3 gap-3">
              <% (availableFeatures || []).forEach(feat => { %>
                <label class="flex items-center gap-2 text-sm font-medium text-gray-700">
                  <input type="checkbox" name="features" value="<%= feat %>" class="accent-blue-600" <%= Array.isArray(vps.features) && vps.features.includes(feat) ? 'checked' : '' %>>
                  <span><%= feat %></span>
                </label>
              <% }) %>
            </div>
          </div>
          <input type="text" name="newFeature" class="w-full bg-white border border-gray-200 p-2 text-sm rounded-lg" placeholder="Nhập tính năng mới...">
        </div>

        <div class="md:col-span-12"><label class="block text-xs font-bold text-gray-500 uppercase mb-2">Mô tả nội bộ</label><textarea name="description" rows="4" class="w-full bg-gray-50 border border-gray-200 p-3 rounded-xl"><%= vps.description || '' %></textarea></div>
        <div class="md:col-span-12"><button type="submit" class="bg-gray-900 text-white w-full py-4 uppercase rounded-xl font-bold hover:bg-blue-600 transition shadow-lg"><i class="fa-solid fa-floppy-disk mr-2"></i>Cập nhật VPS</button></div>
      </form>
    </div>
  </main>

  <script>
    function toggleDuration() {
      const until = document.querySelector('input[name="durationKind"][value="until_date"]').checked;
      document.getElementById('wrap-days').classList.toggle('hidden', until);
      document.getElementById('wrap-until').classList.toggle('hidden', !until);
    }
  </script>
</body>
</html>
