<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <title>Voucher - Admin</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.6.0/css/all.min.css">
  <style>body { font-family: 'Inter', system-ui, sans-serif; background-color: #f3f4f6; }</style>
</head>
<body class="flex min-h-screen text-sm">

  <aside class="w-64 bg-gray-900 text-white min-h-screen flex flex-col fixed shadow-xl z-20">
    <div class="px-6 py-5 bg-gray-800 text-xl font-bold tracking-widest text-center border-b border-gray-700">AdminPanel</div>
    <nav class="flex-1 mt-6 space-y-2 px-4">
      <a href="/admin" class="flex items-center gap-3 px-4 py-3 rounded-lg text-gray-400 hover:text-white hover:bg-gray-800 transition">
        <i class="fa-solid fa-chart-pie w-5"></i> Tổng Quan
      </a>
      <a href="/admin/vps" class="flex items-center gap-3 px-4 py-3 rounded-lg text-gray-400 hover:text-white hover:bg-gray-800 transition">
        <i class="fa-solid fa-server w-5"></i> Quản Lý Dịch Vụ
      </a>
      <a href="/admin/fix-requests" class="flex items-center gap-3 px-4 py-3 rounded-lg text-gray-400 hover:text-white hover:bg-gray-800 transition">
        <i class="fa-solid fa-screwdriver-wrench w-5"></i> Đơn fix lỗi
      </a>
      <a href="/admin/vouchers" class="flex items-center gap-3 px-4 py-3 rounded-lg bg-amber-600 text-white shadow-lg shadow-amber-900/30">
        <i class="fa-solid fa-ticket w-5"></i> Voucher
      </a>
      <a href="/admin/users" class="flex items-center gap-3 px-4 py-3 rounded-lg text-gray-400 hover:text-white hover:bg-gray-800 transition">
        <i class="fa-solid fa-users w-5"></i> Danh sách Khách
      </a>
      <a href="/admin/logs" class="flex items-center gap-3 px-4 py-3 rounded-lg text-gray-400 hover:text-white hover:bg-gray-800 transition">
        <i class="fa-solid fa-clock-rotate-left w-5"></i> Báo cáo Log
      </a>
      <a href="/admin/settings/support" class="flex items-center gap-3 px-4 py-3 rounded-lg text-gray-400 hover:text-white hover:bg-gray-800 transition">
        <i class="fa-solid fa-headset w-5"></i> Liên hệ hỗ trợ
      </a>
      <a href="/admin/settings/promo-modal" class="flex items-center gap-3 px-4 py-3 rounded-lg text-gray-400 hover:text-white hover:bg-gray-800 transition">
        <i class="fa-solid fa-bullhorn w-5"></i> Modal Quảng Cáo
      </a>
    </nav>
    <div class="p-6">
      <a href="/" class="block w-full py-3 text-center bg-gray-800 hover:bg-gray-700 text-gray-300 font-medium rounded-xl transition"><i class="fa-solid fa-house"></i> Về Website</a>
    </div>
  </aside>

  <main class="flex-1 ml-64 flex flex-col min-h-screen">
    <header class="bg-white h-16 border-b flex items-center justify-between px-8 shadow-sm">
      <div class="font-bold text-gray-800 text-lg border-l-4 border-amber-500 pl-3">Voucher giảm giá</div>
      <div class="flex items-center gap-5">
        <span class="font-bold text-gray-900 px-3 py-1 bg-gray-100 rounded-lg"><i class="fa-solid fa-shield-halved text-blue-500 mr-2"></i><%= admin.username %></span>
        <a href="/logout" class="text-red-500 hover:text-red-700 font-bold">Đăng Xuất</a>
      </div>
    </header>

    <div class="p-8 flex-1">
      <% if (typeof flashError !== 'undefined' && flashError) { %>
      <div class="mb-6 p-4 rounded-xl bg-red-50 border border-red-200 text-red-800 font-semibold"><%= flashError %></div>
      <% } %>
      <% if (typeof flashOk !== 'undefined' && flashOk) { %>
      <div class="mb-6 p-4 rounded-xl bg-emerald-50 border border-emerald-200 text-emerald-800 font-semibold">Đã tạo voucher.</div>
      <% } %>

      <div class="grid lg:grid-cols-2 gap-8 items-start">
        <div class="bg-white rounded-2xl shadow-sm border border-gray-100 p-6">
          <h2 class="text-lg font-extrabold text-gray-900 mb-4 border-l-4 border-amber-500 pl-3">Thêm voucher</h2>
          <form action="/admin/vouchers/add" method="POST" class="space-y-4">
            <div>
              <label class="block text-xs font-bold text-gray-500 uppercase mb-1">Mã (khách nhập khi mua)</label>
              <input type="text" name="code" required maxlength="40" placeholder="VD: SALE50" class="w-full border border-gray-200 rounded-xl px-4 py-2.5 font-mono font-bold uppercase outline-none focus:ring-2 focus:ring-amber-500/30">
            </div>
            <div class="grid grid-cols-2 gap-3">
              <div>
                <label class="block text-xs font-bold text-gray-500 uppercase mb-1">Kiểu giảm</label>
                <select name="discountType" class="w-full border border-gray-200 rounded-xl px-4 py-2.5 outline-none focus:ring-2 focus:ring-amber-500/30">
                  <option value="percent">Phần trăm (%)</option>
                  <option value="fixed">Số tiền cố định (VNĐ)</option>
                </select>
              </div>
              <div>
                <label class="block text-xs font-bold text-gray-500 uppercase mb-1">Giá trị</label>
                <input type="number" name="discountValue" required min="1" step="1" placeholder="20 hoặc 50000" class="w-full border border-gray-200 rounded-xl px-4 py-2.5 outline-none focus:ring-2 focus:ring-amber-500/30">
              </div>
            </div>
            <div class="grid grid-cols-2 gap-3">
              <div>
                <label class="block text-xs font-bold text-gray-500 uppercase mb-1">Tối đa số lượt (trống = không giới hạn)</label>
                <input type="number" name="maxUses" min="1" step="1" placeholder="100" class="w-full border border-gray-200 rounded-xl px-4 py-2.5 outline-none focus:ring-2 focus:ring-amber-500/30">
              </div>
              <div>
                <label class="block text-xs font-bold text-gray-500 uppercase mb-1">Hết hạn (tuỳ chọn)</label>
                <input type="datetime-local" name="expiresAt" class="w-full border border-gray-200 rounded-xl px-4 py-2.5 outline-none focus:ring-2 focus:ring-amber-500/30">
              </div>
            </div>
            <div>
              <label class="block text-xs font-bold text-gray-500 uppercase mb-1">Giá gói tối thiểu để áp dụng (VNĐ)</label>
              <input type="number" name="minOrderAmount" min="0" step="1000" value="0" class="w-full border border-gray-200 rounded-xl px-4 py-2.5 outline-none focus:ring-2 focus:ring-amber-500/30">
            </div>
            <div>
              <label class="block text-xs font-bold text-gray-500 uppercase mb-1">Ghi chú nội bộ</label>
              <input type="text" name="note" maxlength="500" placeholder="Tuỳ chọn" class="w-full border border-gray-200 rounded-xl px-4 py-2.5 outline-none focus:ring-2 focus:ring-amber-500/30">
            </div>
            <button type="submit" class="w-full py-3 rounded-xl bg-gray-900 text-white font-bold hover:bg-amber-600 transition">Tạo voucher</button>
          </form>
        </div>

        <div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
          <div class="px-6 py-4 border-b border-gray-100 font-extrabold text-gray-900">Danh sách</div>
          <div class="overflow-x-auto max-h-[70vh] overflow-y-auto">
            <table class="w-full text-left text-xs">
              <thead class="bg-gray-50 text-gray-500 uppercase sticky top-0">
                <tr>
                  <th class="px-4 py-3 font-bold">Mã</th>
                  <th class="px-4 py-3 font-bold">Giảm</th>
                  <th class="px-4 py-3 font-bold">Lượt</th>
                  <th class="px-4 py-3 font-bold">Hết hạn</th>
                  <th class="px-4 py-3 font-bold">TT</th>
                  <th class="px-4 py-3 font-bold"></th>
                </tr>
              </thead>
              <tbody class="divide-y divide-gray-100">
                <% (vouchers || []).forEach(function (v) { %>
                <tr class="hover:bg-gray-50">
                  <td class="px-4 py-3 font-mono font-bold text-amber-700"><%= v.code %></td>
                  <td class="px-4 py-3">
                    <%= v.discountType === 'percent' ? v.discountValue + '%' : v.discountValue.toLocaleString() + 'đ' %>
                    <% if (v.minOrderAmount > 0) { %><div class="text-[10px] text-gray-400">Đơn tối thiểu <%= v.minOrderAmount.toLocaleString() %>đ</div><% } %>
                  </td>
                  <td class="px-4 py-3 text-gray-600"><%= v.usedCount %><% if (v.maxUses != null) { %> / <%= v.maxUses %><% } else { %> / ∞<% } %></td>
                  <td class="px-4 py-3 text-gray-600 whitespace-nowrap"><%= v.expiresAt ? new Date(v.expiresAt).toLocaleString('vi-VN') : '—' %></td>
                  <td class="px-4 py-3">
                    <% if (v.isActive) { %><span class="text-emerald-600 font-bold">Bật</span><% } else { %><span class="text-gray-400">Tắt</span><% } %>
                  </td>
                  <td class="px-4 py-3">
                    <div class="flex flex-wrap gap-1">
                      <form action="/admin/vouchers/toggle" method="POST" class="inline">
                        <input type="hidden" name="voucherId" value="<%= v._id %>">
                        <button type="submit" class="text-xs font-bold text-blue-600 hover:underline">Đổi</button>
                      </form>
                      <form action="/admin/vouchers/delete" method="POST" class="inline" onsubmit="return confirm('Ẩn voucher này? (Không xóa khỏi server)');">
                        <input type="hidden" name="voucherId" value="<%= v._id %>">
                        <button type="submit" class="text-xs font-bold text-red-600 hover:underline">Ẩn</button>
                      </form>
                    </div>
                  </td>
                </tr>
                <% }) %>
                <% if (!(vouchers || []).length) { %>
                <tr><td colspan="6" class="px-4 py-10 text-center text-gray-500">Chưa có voucher</td></tr>
                <% } %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
  </main>
</body>
</html>
