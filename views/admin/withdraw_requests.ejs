<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <title>Đơn rút tiền - VPS Phong Admin</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.6.0/css/all.min.css">
  <style>body { font-family: 'Inter', system-ui, sans-serif; background-color: #f3f4f6; }</style>
</head>
<body class="flex min-h-screen text-sm">
  <%- include('partials/sidebar', { activeMenu: 'withdraw_requests' }) %>

  <main class="flex-1 ml-64 flex flex-col min-h-screen">
    <header class="bg-white h-16 border-b flex items-center justify-between px-8 shadow-sm">
      <div class="font-bold text-gray-800 text-lg border-l-4 border-blue-500 pl-3">Duyệt Đơn Rút Tiền</div>
      <div class="flex items-center gap-5">
        <span class="font-bold text-gray-900 px-3 py-1 bg-gray-100 rounded-lg"><i class="fa-solid fa-shield-halved text-blue-500 mr-2"></i><%= admin.username %></span>
        <a href="/logout" class="text-red-500 hover:text-red-700 font-bold">Đăng Xuất</a>
      </div>
    </header>

    <div class="p-8">
      <div class="bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden">
        <div class="px-6 py-4 border-b border-gray-100 font-bold text-gray-700">Danh sách yêu cầu rút tiền</div>
        <div class="overflow-x-auto">
          <table class="w-full text-left">
            <thead class="bg-gray-50 text-xs uppercase tracking-wide text-gray-500 border-b border-gray-100">
              <tr>
                <th class="px-5 py-3 font-bold">Mã đơn</th>
                <th class="px-5 py-3 font-bold">Khách hàng</th>
                <th class="px-5 py-3 font-bold">Số tiền</th>
                <th class="px-5 py-3 font-bold">Thông tin nhận</th>
                <th class="px-5 py-3 font-bold">Trạng thái</th>
                <th class="px-5 py-3 font-bold">Tạo lúc</th>
                <th class="px-5 py-3 font-bold">Thao tác</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-gray-100">
              <% list.forEach(tx => { %>
              <tr class="hover:bg-gray-50/70">
                <td class="px-5 py-3 font-mono font-bold text-cyan-700"><%= tx.orderNumber || '—' %></td>
                <td class="px-5 py-3">
                  <div class="font-bold text-gray-900"><%= tx.userId?.username || '—' %></div>
                  <div class="text-xs text-gray-500"><%= tx.userId?.email || '' %></div>
                </td>
                <td class="px-5 py-3 font-bold text-rose-600">-<%= Number(tx.amount || 0).toLocaleString() %>đ</td>
                <td class="px-5 py-3 text-xs text-gray-700">
                  <div><strong>NH:</strong> <%= tx.withdrawInfo?.bankName || '—' %></div>
                  <div><strong>STK:</strong> <%= tx.withdrawInfo?.accountNumber || '—' %></div>
                  <div><strong>Tên:</strong> <%= tx.withdrawInfo?.accountName || '—' %></div>
                  <% if (tx.withdrawInfo?.note) { %><div><strong>Ghi chú:</strong> <%= tx.withdrawInfo.note %></div><% } %>
                </td>
                <td class="px-5 py-3">
                  <% if (tx.status === 'pending') { %>
                    <span class="px-2.5 py-1 rounded-full text-[11px] font-bold bg-amber-100 text-amber-800">Chờ duyệt</span>
                  <% } else if (tx.status === 'success') { %>
                    <span class="px-2.5 py-1 rounded-full text-[11px] font-bold bg-emerald-100 text-emerald-700">Đã duyệt</span>
                  <% } else { %>
                    <span class="px-2.5 py-1 rounded-full text-[11px] font-bold bg-gray-100 text-gray-700"><%= tx.status %></span>
                  <% } %>
                </td>
                <td class="px-5 py-3 text-xs text-gray-600"><%= new Date(tx.createdAt).toLocaleString('vi-VN') %></td>
                <td class="px-5 py-3">
                  <% if (tx.status === 'pending') { %>
                  <form action="/admin/withdraw-requests/<%= tx._id %>/approve" method="POST">
                    <button type="submit" class="px-3 py-2 rounded-lg bg-emerald-600 hover:bg-emerald-700 text-white text-[11px] font-bold uppercase">Chấp nhận</button>
                  </form>
                  <% } else { %>
                  <span class="text-xs text-gray-400">—</span>
                  <% } %>
                </td>
              </tr>
              <% }) %>
              <% if (!list.length) { %>
              <tr><td colspan="7" class="px-5 py-10 text-center text-gray-400 font-medium">Chưa có yêu cầu rút tiền</td></tr>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </main>
</body>
</html>
